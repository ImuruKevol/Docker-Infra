# Docker Infra runtime environment template.
# The installer creates /etc/docker-infra/docker-infra.env automatically.

DOCKER_INFRA_DB_HOST=127.0.0.1
DOCKER_INFRA_DB_PORT=5432
DOCKER_INFRA_DB_NAME=docker_infra
DOCKER_INFRA_DB_USER=docker_infra
DOCKER_INFRA_DB_PASSWORD=
DOCKER_INFRA_DB_SCHEMA=public

DOCKER_INFRA_SECRET_KEY=
DOCKER_INFRA_DATA_DIR=/var/lib/docker-infra/data
DOCKER_INFRA_SSH_KEY_DIR=/var/lib/docker-infra/ssh
DOCKER_INFRA_BACKUP_HARBOR_DATA_DIR=/var/lib/docker-infra/backup-harbor
DOCKER_INFRA_BACKUP_HARBOR_HTTP_PORT=5000
DOCKER_INFRA_BACKUP_HARBOR_HTTPS_PORT=5443
DOCKER_INFRA_SESSION_COOKIE_SECURE=false

DOCKER_INFRA_SYSTEM_CODEX_BIN=/usr/local/bin/codex
DOCKER_INFRA_CODEX_BIN=/opt/docker-infra/codex-custom/bin/docker-infra-codex
DOCKER_INFRA_CODEX_AUTO_BUILD=0
CODEX_HOME=/var/lib/docker-infra/codex-home
