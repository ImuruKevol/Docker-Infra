div(class="relative z-[100]", *ngIf="model.isshow")
    div(class="fixed inset-0 bg-zinc-950/55 transition-opacity")
    div(class="fixed inset-0 z-[100] flex items-center justify-center overflow-y-auto px-4 py-6")
        section(role="dialog", aria-modal="true", class="w-full max-w-lg overflow-hidden rounded-md border border-zinc-200 bg-white text-left shadow-2xl dark:border-zinc-800 dark:bg-zinc-900")
            div(class="flex items-start gap-3 border-b border-zinc-200 px-5 py-4 dark:border-zinc-800")
                span(class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-md", [ngClass]="statusIconWrapClass()")
                    i(class="fa-solid text-base", [ngClass]="statusIconClass()")
                div(class="min-w-0")
                    h3(class="text-base font-semibold leading-6 text-zinc-950 dark:text-zinc-50") {{model.opts.title}}
                    p(class="mt-1 whitespace-pre-wrap text-sm leading-6 text-zinc-600 dark:text-zinc-300") {{model.opts.message}}
            div(class="flex flex-col gap-2 border-t border-zinc-200 bg-zinc-50 px-5 py-4 dark:border-zinc-800 dark:bg-zinc-950/60 sm:flex-row sm:justify-end")
                button(
                    type="button",
                    *ngIf="model.opts.cancel",
                    (click)="model.cancel()",
                    class="inline-flex h-9 min-w-[76px] items-center justify-center rounded-md border border-zinc-300 bg-white px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800") {{cancelText()}}
                button(
                    type="button",
                    [class]="btnColorClass()",
                    *ngIf="model.opts.action",
                    (click)="model.action()") {{model.opts.action}}
