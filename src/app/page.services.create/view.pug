header(class="sticky top-0 z-20 border-b border-zinc-200 bg-white/95 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/95")
    div(class="px-5 py-4")
        div(class="flex items-center gap-2 text-xs font-medium text-zinc-500 dark:text-zinc-400")
            a(routerLink="/services", class="hover:text-zinc-950 dark:hover:text-zinc-100") 서비스
            i(class="fa-solid fa-chevron-right text-[10px]")
            span 새 서비스
        h1(class="mt-1 text-xl font-semibold text-zinc-950 dark:text-zinc-50") 새 서비스 만들기

main(class="px-5 pb-24 pt-5")
    div(*ngIf="loading()", class="h-32 rounded-md border border-zinc-200 bg-white p-5 text-sm text-zinc-500 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-400") 정보를 불러오는 중입니다.
    div(*ngIf="error()", class="rounded-md border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700 dark:border-rose-900/70 dark:bg-rose-950/40 dark:text-rose-300") {{error()}}

    section(*ngIf="!loading() && !error()", class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
        section(class="px-5 py-5")
            div(class="flex flex-col gap-3")
                div(class="min-w-0")
                    div(class="flex items-center gap-2")
                        span(class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-zinc-950 text-xs font-semibold text-white dark:bg-zinc-100 dark:text-zinc-950") 1
                        h2(class="text-base font-semibold text-zinc-950 dark:text-zinc-50") 템플릿 선택
                    p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") 생성할 서비스의 기준 템플릿을 먼저 선택합니다.
                    span(class="mt-2 inline-flex h-7 items-center rounded-md border border-zinc-200 bg-zinc-50 px-2.5 text-xs font-semibold text-zinc-600 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-300") 템플릿 {{templates().length}}개

                wiz-component-search-select([items]="templateSelectorItems()", [value]="selectedTemplateId()", (valueChange)="selectTemplate($event)", [placeholder]="'템플릿 선택'", [searchPlaceholder]="'템플릿 검색'", [emptyText]="'등록된 템플릿이 없습니다.'")

                div(*ngIf="selectedTemplateId()", class="relative inline-flex max-w-full items-center gap-2")
                    button(type="button", (click)="toggleTemplateReadme()", title="README 보기", aria-label="README 보기", [attr.aria-expanded]="readmeOpen()", class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-zinc-300 bg-white text-xs text-zinc-500 hover:bg-zinc-50 hover:text-zinc-900 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-300 dark:hover:bg-zinc-800 dark:hover:text-zinc-50")
                        i(class="fa-solid fa-circle-question")
                    span(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") README
                    span(*ngIf="templateLoading()", class="inline-flex items-center gap-1 text-xs font-semibold text-zinc-500 dark:text-zinc-400")
                        i(class="fa-solid fa-spinner fa-spin")
                        span 로딩 중
                    div(*ngIf="readmeOpen()", class="absolute left-0 top-10 z-40 w-[calc(100vw-2.5rem)] max-w-2xl rounded-md border border-zinc-200 bg-white shadow-xl dark:border-zinc-700 dark:bg-zinc-950 sm:w-[42rem]")
                        span(class="absolute -top-1 left-3 h-2 w-2 rotate-45 border-l border-t border-zinc-200 bg-white dark:border-zinc-700 dark:bg-zinc-950")
                        div(class="flex items-center justify-between gap-3 border-b border-zinc-200 px-3 py-2 dark:border-zinc-800")
                            p(class="text-xs font-semibold text-zinc-950 dark:text-zinc-50") README
                            button(type="button", (click)="closeTemplateReadme()", class="inline-flex h-7 w-7 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 hover:text-zinc-950 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-50", aria-label="README 닫기")
                                i(class="fa-solid fa-xmark")
                        pre(class="max-h-72 overflow-auto whitespace-pre-wrap px-3 py-3 text-xs leading-5 text-zinc-700 dark:text-zinc-200") {{selectedTemplateReadme() || 'README가 등록되어 있지 않습니다.'}}

        section(class="border-t border-zinc-200 px-5 py-5 dark:border-zinc-800")
            div(class="flex items-center gap-2")
                span(class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-zinc-100 text-xs font-semibold text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300") 2
                h2(class="text-base font-semibold text-zinc-950 dark:text-zinc-50") 기본 정보
            div(class="mt-4 space-y-4")
                label(class="block")
                    span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 서비스 이름
                    input(type="text", [(ngModel)]="form.name", (blur)="syncDomain()", [placeholder]="serviceNamePlaceholder()", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                label(class="block")
                    span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 설명
                    textarea(rows="3", [(ngModel)]="form.description", placeholder="서비스 설명", class="w-full resize-y rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")

        section(class="border-t border-zinc-200 px-5 py-5 dark:border-zinc-800")
            div(class="flex min-w-0 items-center gap-2")
                span(class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-zinc-100 text-xs font-semibold text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300") 3
                h2(class="text-base font-semibold text-zinc-950 dark:text-zinc-50") 템플릿 변수
            div(class="mt-2 flex flex-wrap items-center gap-2")
                span(*ngIf="templateLoading()", class="inline-flex h-7 items-center gap-2 text-xs font-semibold text-zinc-500 dark:text-zinc-400")
                    i(class="fa-solid fa-spinner fa-spin")
                    span 로딩 중
                span(class="inline-flex h-7 items-center rounded-md border border-zinc-200 bg-zinc-50 px-2.5 text-xs font-semibold text-zinc-600 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-300") 변수 {{editableTemplateFields().length}}개

            div(class="mt-4")
                div(*ngIf="!templateLoading() && !selectedTemplateId()", class="rounded-md border border-dashed border-zinc-300 px-4 py-10 text-center text-sm text-zinc-500 dark:border-zinc-700 dark:text-zinc-400") 템플릿을 선택해주세요.
                div(*ngIf="templateLoading()", class="flex h-24 items-center gap-2 rounded-md border border-zinc-200 px-4 text-sm text-zinc-500 dark:border-zinc-800 dark:text-zinc-400")
                    i(class="fa-solid fa-spinner fa-spin")
                    span 템플릿 정보를 불러오는 중입니다.
                div(*ngIf="!templateLoading() && templateDetail()", class="space-y-4")
                    div(*ngIf="editableTemplateFields().length === 0", class="rounded-md border border-dashed border-zinc-300 px-4 py-10 text-center text-sm text-zinc-500 dark:border-zinc-700 dark:text-zinc-400") 입력할 템플릿 변수가 없습니다.
                    div(*ngIf="editableTemplateFields().length > 0", class="space-y-3")
                        label(*ngFor="let field of editableTemplateFields()", class="block")
                            span(class="mb-1 flex items-center gap-1 text-xs font-semibold text-zinc-500 dark:text-zinc-400")
                                span {{field.title || field.name}}
                                span(*ngIf="field.required", class="text-rose-500") *
                                span(*ngIf="field.secret", class="rounded border border-zinc-300 px-1.5 py-0.5 text-[10px] font-semibold text-zinc-500 dark:border-zinc-700 dark:text-zinc-300") 비밀
                            select(*ngIf="field.enum?.length", [(ngModel)]="templateValues[field.name]", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                                option(*ngFor="let option of field.enum", [ngValue]="option") {{option}}
                            div(*ngIf="!field.enum?.length", class="relative")
                                input([type]="templateFieldInputType(field)", [(ngModel)]="templateValues[field.name]", [placeholder]="templateFieldPlaceholder(field)", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100", [ngClass]="field.secret ? 'pr-10' : ''")
                                button(*ngIf="field.secret", type="button", (click)="toggleSecretField(field)", [title]="secretFieldToggleLabel(field)", [attr.aria-label]="secretFieldToggleLabel(field)", class="absolute right-1 top-1 inline-flex h-8 w-8 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 hover:text-zinc-950 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-50")
                                    i(class="fa-solid", [ngClass]="secretFieldToggleIcon(field)")
                            p(*ngIf="field.description", class="mt-1 text-[11px] leading-4 text-zinc-500 dark:text-zinc-400") {{field.description}}
                            p(*ngIf="field.secret", class="mt-1 text-[11px] leading-4 text-zinc-500 dark:text-zinc-400") 자동 생성된 기본값입니다.

        section(class="border-t border-zinc-200 px-5 py-5 dark:border-zinc-800")
            div(class="flex min-w-0 items-center gap-2")
                span(class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-zinc-100 text-xs font-semibold text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300") 4
                h2(class="text-base font-semibold text-zinc-950 dark:text-zinc-50") 도메인 설정
            div(*ngIf="domainsLoading()", class="mt-2 flex items-center gap-2 text-xs font-semibold text-zinc-500 dark:text-zinc-400")
                i(class="fa-solid fa-spinner fa-spin")
                span 로딩 중

            div(class="mt-4 space-y-3")
                div(class="space-y-2")
                    button(type="button", (click)="setDomainMode('registered')", [disabled]="domainsLoading() || zones().length === 0 || templateBusy() || templateLoading()", class="flex w-full items-center justify-between gap-3 rounded-md border px-3 py-3 text-left transition disabled:cursor-not-allowed disabled:opacity-50", [ngClass]="form.domain_mode === 'registered' ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-200 bg-white text-zinc-700 hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-300 dark:hover:bg-zinc-800'")
                        span(class="flex min-w-0 items-center gap-3")
                            i(class="fa-solid fa-globe")
                            span(class="text-sm font-semibold") DDNS 사용
                        i(*ngIf="form.domain_mode === 'registered'", class="fa-solid fa-check")
                    button(type="button", (click)="setDomainMode('none')", class="flex w-full items-center justify-between gap-3 rounded-md border px-3 py-3 text-left transition", [ngClass]="form.domain_mode === 'none' ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-200 bg-white text-zinc-700 hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-300 dark:hover:bg-zinc-800'")
                        span(class="flex min-w-0 items-center gap-3")
                            i(class="fa-solid fa-ban")
                            span(class="text-sm font-semibold") 사용 안 함
                        i(*ngIf="form.domain_mode === 'none'", class="fa-solid fa-check")

                div(*ngIf="zones().length === 0 && !domainsLoading()", class="rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-800 dark:border-amber-900/70 dark:bg-amber-950/30 dark:text-amber-200") 등록된 DDNS 관리 서버가 없습니다.
                div(*ngIf="form.domain_mode === 'registered'", class="space-y-4")
                    label(class="block")
                        span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 앞 주소
                        input(type="text", [(ngModel)]="form.domain_prefix", (blur)="syncDomain()", placeholder="예: app", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                    label(class="block")
                        span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") DDNS suffix
                        wiz-component-search-select([items]="zoneSelectorItems()", [value]="form.zone_id", (valueChange)="selectZone($event)", [placeholder]="'DDNS suffix 선택'", [searchPlaceholder]="'DDNS suffix 검색'", [emptyText]="'등록된 DDNS 관리 서버가 없습니다.'")
                    div(class="space-y-2")
                        p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") 연결 포트
                        div(*ngIf="domainTargetOptions().length > 0", class="space-y-2")
                            button(*ngFor="let option of domainTargetOptions()", type="button", (click)="selectDomainTarget(option.key)", class="flex w-full items-center justify-between gap-3 rounded-md border px-3 py-2 text-left transition-colors", [ngClass]="form.domain_target_key === option.key ? 'border-sky-300 bg-sky-50 text-sky-800 dark:border-sky-900/70 dark:bg-sky-950/30 dark:text-sky-200' : 'border-zinc-200 bg-white text-zinc-700 hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-300 dark:hover:bg-zinc-800'")
                                span(class="min-w-0")
                                    span(class="flex items-center gap-2 text-sm font-semibold")
                                        span {{option.port}}/{{option.protocol || 'tcp'}}
                                        span(*ngIf="option.recommended", class="rounded border border-sky-300 px-1.5 py-0.5 text-[10px] font-semibold text-sky-700 dark:border-sky-700 dark:text-sky-300") 추천
                                    span(class="mt-0.5 block truncate text-xs text-zinc-500 dark:text-zinc-400") {{option.service_label || option.label}}
                                i(*ngIf="form.domain_target_key === option.key", class="fa-solid fa-check")
                        p(*ngIf="domainTargetOptions().length === 0", class="rounded-md border border-dashed border-zinc-300 px-3 py-3 text-xs text-zinc-500 dark:border-zinc-700 dark:text-zinc-400") 생성 시 템플릿을 적용한 뒤 연결 포트를 확인합니다.

        section(class="border-t border-zinc-200 px-5 py-5 dark:border-zinc-800")
            div(class="flex items-center gap-2")
                span(class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-zinc-100 text-xs font-semibold text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300") 5
                h2(class="text-base font-semibold text-zinc-950 dark:text-zinc-50") 생성 요약
            div(class="mt-4 divide-y divide-zinc-100 rounded-md border border-zinc-200 text-sm dark:divide-zinc-800 dark:border-zinc-800")
                div(class="px-3 py-3")
                    p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") 템플릿
                    p(class="mt-1 font-semibold text-zinc-950 dark:text-zinc-50") {{selectedTemplate()?.name || selectedTemplate()?.namespace || '-'}}
                div(class="px-3 py-3")
                    p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") 이름
                    p(class="mt-1 font-semibold text-zinc-950 dark:text-zinc-50") {{form.name || '-'}}
                div(class="px-3 py-3")
                    p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") 도메인
                    p(class="mt-1 break-all font-semibold text-zinc-950 dark:text-zinc-50") {{domainPreview()}}
                div(class="px-3 py-3")
                    p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") 연결
                    p(class="mt-1 break-words font-semibold text-zinc-950 dark:text-zinc-50") {{selectedDomainTargetLabel()}}

div(*ngIf="!loading() && !error()", class="sticky bottom-0 z-30 border-t border-zinc-200 bg-white/95 px-5 py-3 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/95")
    div(class="flex flex-col-reverse gap-2 sm:flex-row sm:items-center sm:justify-between")
        button(type="button", (click)="cancel()", [disabled]="createBusy()", class="inline-flex h-10 items-center justify-center gap-2 rounded-md border border-zinc-300 bg-white px-4 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-50 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800")
            i(class="fa-solid fa-arrow-left")
            span 목록으로 돌아가기
        button(type="button", (click)="save(true)", [disabled]="createBusy() || templateLoading() || !selectedTemplateId()", class="inline-flex h-10 items-center justify-center gap-2 rounded-md bg-zinc-950 px-5 text-sm font-semibold text-white hover:bg-zinc-800 disabled:opacity-60 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200")
            i(class="fa-solid", [ngClass]="createButtonIconClass()")
            span {{createButtonLabel()}}

div(*ngIf="createCheck().open", class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 px-4 py-6")
    div(class="w-full max-w-2xl rounded-md border border-zinc-200 bg-white shadow-2xl dark:border-zinc-800 dark:bg-zinc-900")
        div(class="flex items-start gap-3 border-b border-zinc-200 px-5 py-4 dark:border-zinc-800")
            span(class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-md", [ngClass]="createCheckStatusClass(createCheck().status)")
                i(class="fa-solid", [ngClass]="createCheckIconClass(createCheck().status)")
            div(class="min-w-0")
                h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{createCheck().title}}
                p(class="mt-1 whitespace-pre-wrap text-xs leading-5 text-zinc-500 dark:text-zinc-400") {{createCheck().message}}
        div(class="px-5 py-4")
            div(*ngIf="createCheckItems().length === 0", class="text-sm text-zinc-500 dark:text-zinc-400")
                i(*ngIf="createCheck().status === 'checking' || createCheck().status === 'creating'", class="fa-solid fa-spinner fa-spin mr-1")
                span {{createCheck().status === 'success' ? '완료되었습니다.' : (createCheck().status === 'error' ? '확인 후 돌아가세요.' : '처리 중입니다.')}}
            div(*ngIf="createCheckItems().length > 0", class="grid grid-cols-1 gap-2 md:grid-cols-2")
                div(*ngFor="let item of createCheckItems()", class="rounded-md border px-3 py-2", [ngClass]="preflightStatusClass(item.status)")
                    div(class="flex items-center justify-between gap-2")
                        p(class="text-xs font-semibold") {{item.title}}
                        span(class="rounded border border-current px-1.5 py-0.5 text-[10px] font-semibold") {{preflightStatusLabel(item.status)}}
                    p(class="mt-1 text-xs leading-5") {{item.message}}
                    p(*ngIf="item.status !== 'ok'", class="mt-1 text-xs leading-5 opacity-90") {{preflightActionText(item)}}
        div(*ngIf="createCheck().status === 'error'", class="flex justify-end border-t border-zinc-200 px-5 py-4 dark:border-zinc-800")
            button(type="button", (click)="closeCreateCheck()", class="inline-flex h-9 items-center justify-center rounded-md border border-zinc-300 bg-white px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800") {{createCheckActionLabel()}}
