                                button(type="button", (click)="saveAdvancedEditor()", [disabled]="busy() || !advancedEditorTarget()?.editable", class="inline-flex h-8 shrink-0 items-center justify-center gap-2 rounded-md border border-amber-300 px-2.5 text-xs font-semibold text-amber-700 hover:bg-amber-50 disabled:opacity-50 dark:border-amber-900/70 dark:text-amber-300 dark:hover:bg-amber-950/30")
