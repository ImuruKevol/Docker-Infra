                    span AI 수정안
                button(type="button", (click)="closeEditModal()", [disabled]="editBusy()", class="inline-flex h-9 w-9 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 disabled:opacity-50 dark:text-zinc-400 dark:hover:bg-zinc-800")
                    i(class="fa-solid fa-xmark")

        div(class="min-h-0 flex-1 lg:flex")
