            div(class="min-h-0 flex-1 overflow-y-auto bg-white dark:bg-zinc-900")
                div(class="sticky top-0 z-10 border-b border-zinc-200 bg-white/95 px-5 py-4 backdrop-blur dark:border-zinc-800 dark:bg-zinc-900/95")
                    h3(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{editSectionTitle()}}
