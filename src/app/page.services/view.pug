                                        span(class="inline-flex rounded-md border border-zinc-200 bg-zinc-50 px-2 py-1 text-xs font-semibold text-zinc-600 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-300") {{versionSourceLabel(version)}}
                                        span(*ngIf="versionSnapshotBackupCount(version) > 0", class="inline-flex items-center gap-1 rounded-md border border-emerald-200 bg-emerald-50 px-2 py-1 text-xs font-semibold text-emerald-700 dark:border-emerald-900/70 dark:bg-emerald-950/40 dark:text-emerald-300")
                                            i(class="fa-solid fa-camera")
                                            span 스냅샷 {{versionSnapshotBackupCount(version)}}
                                        span(*ngIf="versionBackupCount(version) > 0 && versionSnapshotBackupCount(version) === 0", class="inline-flex items-center gap-1 rounded-md border border-sky-200 bg-sky-50 px-2 py-1 text-xs font-semibold text-sky-700 dark:border-sky-900/70 dark:bg-sky-950/40 dark:text-sky-300")
                                            i(class="fa-solid fa-box-archive")
                                            span 백업 {{versionBackupCount(version)}}
                                        button(type="button", (click)="openRollbackModal(version)", [disabled]="busy() || rollbackBusy()", class="inline-flex h-8 items-center gap-1.5 rounded-md border border-zinc-300 px-2.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-60 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800")
                                            i(class="fa-solid fa-rotate-left")
                                            span 되돌리기

div(*ngIf="editModalOpen()", class="fixed inset-0 z-40 flex items-center justify-center px-3 py-4")
