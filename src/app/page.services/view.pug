                        span(class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-md", [ngClass]="editSection() === item.id ? 'bg-white/15 text-white dark:bg-zinc-950/10 dark:text-zinc-950' : 'bg-zinc-100 text-zinc-500 dark:bg-zinc-800 dark:text-zinc-300'")
