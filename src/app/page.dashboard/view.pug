header(class="sticky top-0 z-20 border-b border-zinc-200 bg-white/95 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/95")
    div(class="flex flex-col gap-3 px-5 py-4 md:flex-row md:items-center md:justify-between")
        div
            div(class="flex items-center gap-2 text-xs font-medium text-zinc-500 dark:text-zinc-400")
                i(class="fa-solid fa-gauge-high")
                span Dashboard
            h1(class="mt-1 text-xl font-semibold text-zinc-950 dark:text-zinc-50") Docker Infra
        div(class="flex items-center gap-2")
            span(class="inline-flex items-center gap-1.5 rounded-md border px-2.5 py-1.5 text-xs font-semibold", [ngClass]="statusClass(health()?.status)")
                i(class="fa-solid fa-circle text-[7px]")
                | {{statusLabel(health()?.status)}}
            button(type="button", (click)="load()", class="inline-flex h-9 items-center gap-2 rounded-md border border-zinc-300 bg-white px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800")
                i(class="fa-solid fa-rotate-right")
                span 새로고침

main(class="space-y-6 px-5 py-5")
    div(*ngIf="loading()", class="h-32 rounded-md border border-zinc-200 bg-white p-5 text-sm text-zinc-500 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-400") 정보를 불러오는 중입니다.
    div(*ngIf="error()", class="rounded-md border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700 dark:border-rose-900/70 dark:bg-rose-950/40 dark:text-rose-300") {{error()}}

    div(*ngIf="!loading() && !error()", class="space-y-6")
        section(class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-4")
            div(*ngFor="let stat of stats()", class="rounded-md border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900")
                div(class="flex items-start justify-between gap-3")
                    div
                        p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") {{stat.label}}
                        p(class="mt-2 text-3xl font-semibold text-zinc-950 dark:text-zinc-50") {{stat.value}}
                    div(class="flex h-9 w-9 items-center justify-center rounded-md", [ngClass]="statIconClass(stat.tone)")
                        i(class="fa-solid", [ngClass]="stat.icon")

        section(class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
            div(class="flex flex-col gap-2 border-b border-zinc-200 px-4 py-3 dark:border-zinc-800 md:flex-row md:items-center md:justify-between")
                div
                    h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 서버 자원 추이
                    p(class="mt-0.5 text-xs text-zinc-500 dark:text-zinc-400") {{resourceRangeText()}}
                div(class="flex flex-wrap items-end gap-2")
                    label(class="block")
                        span(class="mb-1 block text-[11px] font-semibold text-zinc-500 dark:text-zinc-400") 시작일
                        input(type="date", [ngModel]="resourceStartDate()", (ngModelChange)="resourceStartDate.set($event)", class="h-8 rounded-md border border-zinc-300 bg-white px-2 text-xs text-zinc-900 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                    label(class="block")
                        span(class="mb-1 block text-[11px] font-semibold text-zinc-500 dark:text-zinc-400") 종료일
                        input(type="date", [ngModel]="resourceEndDate()", (ngModelChange)="resourceEndDate.set($event)", class="h-8 rounded-md border border-zinc-300 bg-white px-2 text-xs text-zinc-900 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                    button(type="button", (click)="applyResourceRange()", [disabled]="resourceChartBusy()", class="inline-flex h-8 items-center gap-2 rounded-md bg-zinc-950 px-2.5 text-xs font-semibold text-white hover:bg-zinc-800 disabled:opacity-50 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200")
                        i(class="fa-solid", [ngClass]="resourceChartBusy() ? 'fa-spinner fa-spin' : 'fa-chart-line'")
                        span 조회
                    button(type="button", (click)="openNodeCharts()", class="inline-flex h-8 items-center gap-2 rounded-md border border-zinc-300 px-2.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800")
                        i(class="fa-solid fa-chart-area")
                        span 서버별 보기
            div(class="p-4")
                div(*ngIf="resourceChartError()", class="mb-3 rounded-md border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700 dark:border-rose-900/70 dark:bg-rose-950/40 dark:text-rose-300") {{resourceChartError()}}
                div(*ngIf="resourceChartBusy() && resourceRows().length === 0", class="flex h-64 items-center justify-center gap-2 rounded-md border border-dashed border-zinc-300 text-sm text-zinc-500 dark:border-zinc-700 dark:text-zinc-400")
                    i(class="fa-solid fa-spinner fa-spin")
                    span 자원 기록을 불러오는 중입니다.
                div(*ngIf="!resourceChartBusy() && resourceRows().length === 0", class="flex h-64 items-center justify-center rounded-md border border-dashed border-zinc-300 text-sm text-zinc-500 dark:border-zinc-700 dark:text-zinc-400") 선택한 기간에 표시할 자원 기록이 없습니다.
                div(*ngIf="resourceRows().length > 0", class="h-64")
                    canvas(data-resource-chart-canvas="dashboard", class="block h-full w-full")

        section(class="grid grid-cols-1 gap-4 xl:grid-cols-[1.1fr_0.9fr]")
            div(class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
                div(class="flex items-center justify-between border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                    div
                        h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") Runtime
                        p(class="mt-0.5 text-xs text-zinc-500 dark:text-zinc-400") 운영 서버, 데이터베이스, 설정 상태를 확인합니다.
                    a(routerLink="/system", class="inline-flex h-8 items-center gap-2 rounded-md border border-zinc-300 px-2.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800")
                        i(class="fa-solid fa-gear")
                        span Settings
                div(class="grid grid-cols-1 divide-y divide-zinc-100 dark:divide-zinc-800 md:grid-cols-3 md:divide-x md:divide-y-0")
                    div(class="p-4")
                        p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Setup
                        p(class="mt-2 text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{setup()?.configured ? 'Configured' : 'Required'}}
                    div(class="p-4")
                        p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Database
                        p(class="mt-2 text-sm font-semibold text-zinc-950 dark:text-zinc-50") v{{health()?.checks?.database?.schema_version || '-'}}
                    div(class="p-4")
                        p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Local master
                        p(class="mt-2 truncate text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{setup()?.local_master?.host || '-'}}

            div(class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
                div(class="border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                    h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") Integrations
                div(class="divide-y divide-zinc-100 dark:divide-zinc-800")
                    div(*ngFor="let integration of integrations()", class="flex items-center justify-between gap-3 px-4 py-3")
                        div(class="min-w-0")
                            p(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{integration.label}}
                            p(class="mt-0.5 truncate text-xs text-zinc-500 dark:text-zinc-400") {{integration.primary || '-'}}
                        span(class="inline-flex rounded-md border px-2 py-1 text-xs font-semibold", [ngClass]="statusClass(integration.enabled ? 'ok' : 'pending')") {{integration.enabled ? '사용 중' : '꺼짐'}}

        section(class="grid grid-cols-1 gap-4 xl:grid-cols-2")
            div(class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
                div(class="flex items-center justify-between border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                    div
                        h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") Servers
                        p(class="mt-0.5 text-xs text-zinc-500 dark:text-zinc-400") {{metricHistoryText()}}
                    a(routerLink="/servers", class="text-xs font-semibold text-sky-700 hover:text-sky-800 dark:text-sky-300") Open
                div(class="divide-y divide-zinc-100 dark:divide-zinc-800")
                    div(*ngFor="let node of nodes()", class="flex flex-col gap-3 px-4 py-3 xl:flex-row xl:items-center xl:justify-between")
                        div(class="min-w-0 flex-1")
                            p(class="truncate text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{node.name}}
                            p(class="mt-0.5 truncate text-xs text-zinc-500 dark:text-zinc-400") {{node.role}} · {{node.host}}
                            div(class="mt-2 flex flex-wrap gap-1.5 text-[11px] font-semibold")
                                span(class="rounded-md border border-sky-200 bg-sky-50 px-2 py-0.5 text-sky-700 dark:border-sky-900/70 dark:bg-sky-950/40 dark:text-sky-300") CPU {{nodeMetricPercent(node, 'cpu')}}
                                span(class="rounded-md border border-emerald-200 bg-emerald-50 px-2 py-0.5 text-emerald-700 dark:border-emerald-900/70 dark:bg-emerald-950/40 dark:text-emerald-300") MEM {{nodeMetricPercent(node, 'memory')}}
                                span(class="rounded-md border border-amber-200 bg-amber-50 px-2 py-0.5 text-amber-700 dark:border-amber-900/70 dark:bg-amber-950/40 dark:text-amber-300") DISK {{nodeMetricPercent(node, 'storage')}}
                                span(class="rounded-md border border-zinc-200 bg-zinc-50 px-2 py-0.5 text-zinc-600 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-300") 컨테이너 {{nodeContainerSummary(node).running || 0}}/{{nodeContainerSummary(node).total || 0}}
                        div(class="flex shrink-0 flex-col items-start gap-1 xl:items-end")
                            span(class="inline-flex rounded-md border px-2 py-1 text-xs font-semibold", [ngClass]="statusClass(node.status)") {{statusLabel(node.status)}}
                            span(class="text-[11px] text-zinc-500 dark:text-zinc-400") {{formatDate(nodeMetric(node).reported_at)}}
                    div(*ngIf="nodes().length === 0", class="px-4 py-8 text-center text-sm text-zinc-500 dark:text-zinc-400") No servers

            div(class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
                div(class="flex items-center justify-between border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                    h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 최근 작업
                    a(routerLink="/tools", class="text-xs font-semibold text-sky-700 hover:text-sky-800 dark:text-sky-300") Tools
                div(class="divide-y divide-zinc-100 dark:divide-zinc-800")
                    div(*ngFor="let operation of operations()", class="flex items-center justify-between gap-3 px-4 py-3")
                        div(class="min-w-0")
                            p(class="truncate text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{operation.type}}
                            p(class="mt-0.5 truncate text-xs text-zinc-500 dark:text-zinc-400") {{formatDate(operation.created_at)}}
                        span(class="inline-flex rounded-md border px-2 py-1 text-xs font-semibold", [ngClass]="statusClass(operation.status)") {{statusLabel(operation.status)}}
                    div(*ngIf="operations().length === 0", class="px-4 py-8 text-center text-sm text-zinc-500 dark:text-zinc-400") 작업 이력이 없습니다.

        div(*ngIf="nodeChartsOpen()", class="fixed inset-0 z-40 flex items-start justify-center bg-zinc-950/40 px-4 py-6 backdrop-blur-sm")
            section(class="max-h-[84vh] w-full max-w-6xl overflow-y-auto rounded-md border border-zinc-200 bg-white shadow-xl dark:border-zinc-800 dark:bg-zinc-950")
                div(class="sticky top-0 z-10 flex flex-col gap-2 border-b border-zinc-200 bg-white px-4 py-3 dark:border-zinc-800 dark:bg-zinc-950 md:flex-row md:items-center md:justify-between")
                    div
                        h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 서버별 자원 추이
                        p(class="mt-0.5 text-xs text-zinc-500 dark:text-zinc-400") {{resourceStartDate()}} ~ {{resourceEndDate()}}
                    button(type="button", (click)="closeNodeCharts()", class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-zinc-300 text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-900")
                        i(class="fa-solid fa-xmark")
                div(class="p-4")
                    div(*ngIf="nodeResourceCharts().length === 0", class="flex h-48 items-center justify-center rounded-md border border-dashed border-zinc-300 text-sm text-zinc-500 dark:border-zinc-700 dark:text-zinc-400") 서버별 자원 기록이 없습니다.
                    div(*ngIf="nodeResourceCharts().length > 0", class="grid grid-cols-1 gap-4 xl:grid-cols-2")
                        div(*ngFor="let chart of nodeResourceCharts()", class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
                            div(class="border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                                h3(class="truncate text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{nodeChartTitle(chart)}}
                                p(class="mt-0.5 truncate text-xs text-zinc-500 dark:text-zinc-400") {{nodeChartSubtitle(chart)}}
                            div(class="p-4")
                                div(*ngIf="nodeChartRows(chart).length === 0", class="flex h-56 items-center justify-center rounded-md border border-dashed border-zinc-300 text-sm text-zinc-500 dark:border-zinc-700 dark:text-zinc-400") 선택한 기간에 표시할 자원 기록이 없습니다.
                                div(*ngIf="nodeChartRows(chart).length > 0", class="h-56")
                                    canvas([attr.data-node-resource-chart-canvas]="chart.node_id", class="block h-full w-full")
