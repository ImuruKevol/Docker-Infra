header(class="sticky top-0 z-20 border-b border-zinc-200 bg-white/95 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/95")
    div(class="flex flex-col gap-3 px-5 py-4 md:flex-row md:items-center md:justify-between")
        div
            div(class="flex items-center gap-2 text-xs font-medium text-zinc-500 dark:text-zinc-400")
                i(class="fa-solid fa-file-code")
                span Templates
            h1(class="mt-1 text-xl font-semibold text-zinc-950 dark:text-zinc-50") 템플릿 관리
        div(class="flex items-center gap-2")
            button(type="button", (click)="openAiModal()", class="inline-flex h-9 items-center gap-2 rounded-md border border-sky-300 bg-white px-3 text-sm font-semibold text-sky-700 hover:bg-sky-50 dark:border-sky-900/70 dark:bg-zinc-900 dark:text-sky-300 dark:hover:bg-sky-950/30")
                i(class="fa-solid fa-wand-magic-sparkles")
                span AI 새 초안
            button(type="button", (click)="openFileTree()", [disabled]="!detail()", class="inline-flex h-9 items-center gap-2 rounded-md border border-zinc-300 bg-white px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-50 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800")
                i(class="fa-solid fa-folder-tree")
                span 파일 관리
            button(type="button", (click)="openCreateModal()", class="inline-flex h-9 items-center gap-2 rounded-md bg-zinc-950 px-3 text-sm font-semibold text-white hover:bg-zinc-800 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200")
                i(class="fa-solid fa-plus")
                span 새 템플릿
            button(type="button", (click)="load(selectedTemplateId())", class="inline-flex h-9 items-center gap-2 rounded-md border border-zinc-300 bg-white px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800")
                i(class="fa-solid fa-rotate-right")
                span 새로고침

main(class="space-y-5 px-5 py-5")
    div(*ngIf="loading()", class="h-32 rounded-md border border-zinc-200 bg-white p-5 text-sm text-zinc-500 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-400") 정보를 불러오는 중입니다.
    div(*ngIf="error()", class="rounded-md border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700 dark:border-rose-900/70 dark:bg-rose-950/40 dark:text-rose-300") {{error()}}

    div(*ngIf="!loading() && !error()", class="space-y-5")
        section(class="grid grid-cols-1 gap-3 md:grid-cols-3")
            div(class="rounded-md border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900")
                p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Template root
                p(class="mt-2 truncate text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{templateRoot() || '-'}}
            div(class="rounded-md border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900")
                p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") 전체 템플릿
                p(class="mt-2 text-2xl font-semibold text-zinc-950 dark:text-zinc-50") {{templates().length}}
            div(class="rounded-md border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900")
                p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") 릴리즈 버전
                p(class="mt-2 text-2xl font-semibold text-zinc-950 dark:text-zinc-50") {{releasedVersionCount()}}

        section(class="grid grid-cols-1 gap-5 xl:grid-cols-[340px_1fr]")
            aside(class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
                div(class="space-y-3 border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                    div(class="flex items-center justify-between gap-3")
                        h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 템플릿 목록
                        span(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") {{templates().length}}
                    label(class="block")
                        span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 검색
                        input(type="text", [ngModel]="search()", (ngModelChange)="search.set($event)", placeholder="이름, 설명, 이미지 검색", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                div(*ngIf="filteredTemplates().length === 0", class="px-4 py-10 text-center text-sm text-zinc-500 dark:text-zinc-400") 등록된 템플릿이 없습니다.
                div(*ngFor="let item of filteredTemplates()", class="border-t border-zinc-100 px-4 py-4 first:border-t-0 dark:border-zinc-800")
                    button(type="button", (click)="selectTemplate(item.id)", class="block w-full text-left", [ngClass]="selectedTemplateId() === item.id ? 'rounded-md bg-sky-50 px-2 py-2 dark:bg-sky-950/30' : ''")
                        div(class="flex items-start justify-between gap-3")
                            div(class="min-w-0")
                                p(class="truncate text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{item.name}}
                                p(class="mt-1 truncate text-xs text-zinc-500 dark:text-zinc-400") {{item.description || '설명 없음'}}
                                p(class="mt-1 truncate text-xs text-zinc-400 dark:text-zinc-500") {{templateImageLabel(item)}}
                            span(class="inline-flex shrink-0 whitespace-nowrap rounded-md border px-2 py-0.5 text-[11px] font-semibold", [ngClass]="statusClass(item.enabled)") {{item.enabled ? '사용 중' : '꺼짐'}}

            section(class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
                div(class="flex flex-col gap-3 border-b border-zinc-200 px-4 py-3 dark:border-zinc-800 lg:flex-row lg:items-start lg:justify-between")
                    div
                        h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{detail()?.template?.name || '템플릿 선택'}}
                        p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") {{detail()?.template?.description || '왼쪽 목록에서 템플릿을 선택하거나 새로 만드세요.'}}
                    div(*ngIf="detail()", class="flex flex-wrap items-center gap-2")
                        button(type="button", (click)="saveTemplate()", [disabled]="busy()", class="inline-flex h-8 items-center gap-2 rounded-md bg-zinc-950 px-2.5 text-xs font-semibold text-white hover:bg-zinc-800 disabled:opacity-60 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200")
                            i(class="fa-solid fa-floppy-disk")
                            span {{busy() ? '저장 중' : '저장'}}
                        button(type="button", (click)="createReleaseVersion()", [disabled]="busy()", class="inline-flex h-8 items-center gap-2 rounded-md border border-sky-300 px-2.5 text-xs font-semibold text-sky-700 hover:bg-sky-50 disabled:opacity-60 dark:border-sky-900/70 dark:text-sky-300 dark:hover:bg-sky-950/30")
                            i(class="fa-solid fa-box-archive")
                            span 버전 만들기
                        button(type="button", (click)="deleteTemplate()", [disabled]="busy()", class="inline-flex h-8 items-center gap-2 rounded-md border border-rose-300 px-2.5 text-xs font-semibold text-rose-700 hover:bg-rose-50 disabled:opacity-50 dark:border-rose-900/70 dark:text-rose-300 dark:hover:bg-rose-950/30")
                            i(class="fa-solid fa-trash")
                            span 삭제
                div(*ngIf="detailLoading()", class="px-4 py-10 text-sm text-zinc-500 dark:text-zinc-400") 템플릿 상세를 불러오는 중입니다.
                div(*ngIf="!detailLoading() && !detail()", class="px-4 py-14 text-center text-sm text-zinc-500 dark:text-zinc-400") 템플릿을 선택하면 Compose와 릴리즈 버전을 여기서 관리할 수 있습니다.
                div(*ngIf="detail()", class="grid grid-cols-1 gap-5 p-4 2xl:grid-cols-[280px_1fr_300px]")
                    div(class="space-y-4")
                        label(class="block")
                            span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 이름
                            input(type="text", [(ngModel)]="detail().template.name", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                        label(class="block")
                            span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 설명
                            textarea([(ngModel)]="detail().template.description", rows="4", class="w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                        div(class="grid grid-cols-1 gap-3")
                            label(class="block")
                                span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 이미지 이름
                                input(type="text", [(ngModel)]="detail().template.metadata.image_name", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                            label(class="block")
                                span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 이미지 버전
                                input(type="text", [(ngModel)]="detail().template.metadata.image_version", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                        label(class="flex items-center gap-2 rounded-md border border-zinc-200 px-3 py-2 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-200")
                            input(type="checkbox", [(ngModel)]="detail().template.enabled")
                            span 이 템플릿 사용
                        div(class="rounded-md border border-zinc-200 px-3 py-3 text-xs text-zinc-500 dark:border-zinc-800 dark:text-zinc-400")
                            p(class="font-semibold text-zinc-700 dark:text-zinc-200") 현재 이미지
                            p(class="mt-2 break-all") {{detail()?.template?.metadata?.image_name || '-'}}<span *ngIf="detail()?.template?.metadata?.image_version">:{{detail()?.template?.metadata?.image_version}}</span>

                    div(class="space-y-4")
                        div(class="flex flex-wrap gap-2")
                            button(type="button", (click)="setEditorTab('compose')", class="inline-flex h-8 items-center rounded-md border px-2.5 text-xs font-semibold", [ngClass]="currentTab() === 'compose' ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-300 bg-white text-zinc-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200'") Compose
                            button(type="button", (click)="setEditorTab('defaults')", class="inline-flex h-8 items-center rounded-md border px-2.5 text-xs font-semibold", [ngClass]="currentTab() === 'defaults' ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-300 bg-white text-zinc-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200'") 기본값
                            button(type="button", (click)="setEditorTab('schema')", class="inline-flex h-8 items-center rounded-md border px-2.5 text-xs font-semibold", [ngClass]="currentTab() === 'schema' ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-300 bg-white text-zinc-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200'") Schema
                            button(type="button", (click)="setEditorTab('readme')", class="inline-flex h-8 items-center rounded-md border px-2.5 text-xs font-semibold", [ngClass]="currentTab() === 'readme' ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-300 bg-white text-zinc-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200'") README
                            button(type="button", (click)="setEditorTab('preview')", class="inline-flex h-8 items-center rounded-md border px-2.5 text-xs font-semibold", [ngClass]="currentTab() === 'preview' ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-300 bg-white text-zinc-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200'") 렌더 미리보기
                            button(type="button", (click)="setEditorTab('versions')", class="inline-flex h-8 items-center rounded-md border px-2.5 text-xs font-semibold", [ngClass]="currentTab() === 'versions' ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-300 bg-white text-zinc-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200'") 버전
                        div(class="rounded-md border border-zinc-200 dark:border-zinc-800")
                            nu-monaco-editor(*ngIf="currentTab() === 'compose'", [(ngModel)]="detail().files['docker-compose.yaml']", [options]="editorOptions", height="560px")
                            nu-monaco-editor(*ngIf="currentTab() === 'defaults'", [(ngModel)]="detail().files['values.default.yaml']", [options]="editorOptions", height="560px")
                            nu-monaco-editor(*ngIf="currentTab() === 'schema'", [(ngModel)]="detail().files['values.schema.json']", [options]="schemaEditorOptions", height="560px")
                            nu-monaco-editor(*ngIf="currentTab() === 'readme'", [(ngModel)]="detail().files['README.md']", [options]="readmeEditorOptions", height="560px")
                            div(*ngIf="currentTab() === 'preview'", class="space-y-4 p-4")
                                div(*ngIf="previewBusy()", class="rounded-md border border-zinc-200 px-3 py-2 text-xs text-zinc-500 dark:border-zinc-800 dark:text-zinc-400")
                                    i(class="fa-solid fa-spinner fa-spin mr-1")
                                    | 현재 편집 중인 내용으로 Compose를 다시 계산하는 중입니다.
                                div(class="rounded-md border border-zinc-200 px-3 py-3 dark:border-zinc-800")
                                    p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") 렌더 기준 값
                                    pre(class="mt-2 max-h-40 overflow-auto rounded-md bg-zinc-950 px-3 py-3 text-xs text-zinc-100") {{detail()?.preview?.values | json}}
                                div(class="rounded-md border border-zinc-200 px-3 py-3 dark:border-zinc-800")
                                    p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Compose 검증 결과
                                    p(class="mt-2 text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{detail()?.preview?.validation?.valid ? '검사 통과' : '검사 실패'}}
                                    p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") Overlay network, deploy policy, healthcheck 규칙까지 포함한 결과입니다.
                                textarea([value]="detail()?.preview?.rendered_compose || ''", rows="22", readonly, class="w-full resize-none rounded-md border border-zinc-300 bg-zinc-950 p-3 font-mono text-xs text-zinc-50 dark:border-zinc-700")
                            div(*ngIf="currentTab() === 'versions'", class="space-y-4 p-4")
                                div(class="flex flex-wrap gap-2")
                                    button(type="button", (click)="setVersionPanelTab('history')", class="inline-flex h-8 items-center rounded-md border px-2.5 text-xs font-semibold", [ngClass]="versionPanelTab() === 'history' ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-300 bg-white text-zinc-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200'") 버전 이력
                                    button(type="button", (click)="setVersionPanelTab('content')", class="inline-flex h-8 items-center rounded-md border px-2.5 text-xs font-semibold", [ngClass]="versionPanelTab() === 'content' ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-300 bg-white text-zinc-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200'") 버전 내용
                                div(*ngIf="versionPanelTab() === 'history'", class="rounded-md border border-zinc-200 dark:border-zinc-800")
                                    div(class="flex items-center justify-between border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                                        h3(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 버전 이력
                                        span(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") {{detail()?.versions?.length || 0}}
                                    div(*ngIf="detail()?.versions?.length === 0", class="px-4 py-10 text-center text-sm text-zinc-500 dark:text-zinc-400") 아직 만든 버전이 없습니다.
                                    div(*ngFor="let version of detail()?.versions", class="border-t border-zinc-100 px-4 py-3 first:border-t-0 dark:border-zinc-800")
                                        button(type="button", (click)="selectVersion(version.id); setVersionPanelTab('content')", class="block w-full text-left", [ngClass]="selectedVersionId() === version.id ? 'rounded-md bg-sky-50 px-2 py-2 dark:bg-sky-950/30' : ''")
                                            div(class="flex items-center justify-between gap-3")
                                                div
                                                    p(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") v{{version.version}}
                                                    p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") {{formatDate(version.created_at)}}
                                                i(class="fa-solid fa-chevron-right text-xs text-zinc-400")
                                div(*ngIf="versionPanelTab() === 'content'", class="rounded-md border border-zinc-200 dark:border-zinc-800")
                                    div(class="border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                                        h3(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 버전 내용
                                    div(*ngIf="versionBusy()", class="px-4 py-10 text-sm text-zinc-500 dark:text-zinc-400")
                                        i(class="fa-solid fa-spinner fa-spin mr-1")
                                        | 버전 내용을 불러오는 중입니다.
                                    div(*ngIf="!versionBusy() && !selectedVersion()", class="px-4 py-10 text-center text-sm text-zinc-500 dark:text-zinc-400") 버전 이력 탭에서 버전을 선택하세요.
                                    div(*ngIf="!versionBusy() && selectedVersion()", class="space-y-4 p-4")
                                        div(class="flex items-start justify-between gap-3")
                                            div
                                                p(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{selectedVersionTitle()}}
                                                p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") {{formatDate(selectedVersion()?.version?.created_at)}}
                                            button(type="button", (click)="setVersionPanelTab('history')", class="inline-flex h-8 items-center gap-2 rounded-md border border-zinc-300 px-2.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800")
                                                i(class="fa-solid fa-list")
                                                span 이력
                                        div(class="flex flex-wrap gap-2")
                                            button(type="button", (click)="setVersionTab('compose')", class="inline-flex h-8 items-center rounded-md border px-2.5 text-xs font-semibold", [ngClass]="selectedVersionTab() === 'compose' ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-300 bg-white text-zinc-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200'") Compose
                                            button(type="button", (click)="setVersionTab('defaults')", class="inline-flex h-8 items-center rounded-md border px-2.5 text-xs font-semibold", [ngClass]="selectedVersionTab() === 'defaults' ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-300 bg-white text-zinc-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200'") 기본값
                                            button(type="button", (click)="setVersionTab('schema')", class="inline-flex h-8 items-center rounded-md border px-2.5 text-xs font-semibold", [ngClass]="selectedVersionTab() === 'schema' ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-300 bg-white text-zinc-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200'") Schema
                                            button(type="button", (click)="setVersionTab('readme')", class="inline-flex h-8 items-center rounded-md border px-2.5 text-xs font-semibold", [ngClass]="selectedVersionTab() === 'readme' ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-300 bg-white text-zinc-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200'") README
                                        textarea([value]="selectedVersionContent()", rows="22", readonly, class="w-full resize-none rounded-md border border-zinc-300 bg-zinc-950 p-3 font-mono text-xs text-zinc-50 dark:border-zinc-700")

                    aside(class="space-y-4")
                        div(class="rounded-md border border-sky-200 bg-sky-50 px-4 py-3 dark:border-sky-900/70 dark:bg-sky-950/30")
                            div(class="flex items-center justify-between gap-3")
                                h3(class="text-sm font-semibold text-sky-950 dark:text-sky-100") AI 수정
                                button(type="button", (click)="generateTemplateEditWithAi()", [disabled]="aiEditBusy()", class="inline-flex h-8 items-center gap-2 rounded-md bg-sky-600 px-2.5 text-xs font-semibold text-white hover:bg-sky-500 disabled:opacity-60")
                                    i(class="fa-solid", [ngClass]="aiEditBusy() ? 'fa-spinner fa-spin' : 'fa-wand-magic-sparkles'")
                                    span {{aiEditBusy() ? '생성 중' : '수정안'}}
                            label(class="mt-3 block")
                                span(class="mb-1 block text-xs font-semibold text-sky-700 dark:text-sky-300") 사용할 모델
                                wiz-component-search-select([items]="aiModelOptions()", [value]="aiEditForm.model_ref", (valueChange)="aiEditForm.model_ref = $event", [placeholder]="'AI 모델 선택'", [searchPlaceholder]="'모델 검색'", [emptyText]="'시스템 설정에서 모델 목록을 불러오세요.'")
                            label(class="mt-3 block")
                                span(class="mb-1 block text-xs font-semibold text-sky-700 dark:text-sky-300") 수정 요청
                                textarea([(ngModel)]="aiEditForm.intent", rows="6", placeholder="예: Redis를 추가하고 앱 포트는 8080으로 바꿔줘. 비밀번호는 자동 생성값으로 처리.", class="w-full resize-none rounded-md border border-sky-200 bg-white px-3 py-2 text-xs text-zinc-900 placeholder:text-zinc-400 dark:border-sky-900/70 dark:bg-zinc-950 dark:text-zinc-100")
                            div(*ngIf="aiEditBusy() || aiEditStreamRows().length", class="mt-3 rounded-md border border-sky-200 bg-white/70 px-3 py-2 dark:border-sky-900/70 dark:bg-zinc-950")
                                div(class="flex items-center justify-between gap-2")
                                    p(class="text-[11px] font-semibold uppercase text-sky-700 dark:text-sky-300") AI 진행 상태
                                    span(class="text-[11px] font-semibold text-sky-500 dark:text-sky-400") {{aiEditOutputTokenCount()}} chars
                                div(class="mt-2 max-h-28 space-y-1 overflow-auto")
                                    p(*ngFor="let event of aiEditStreamRows()", class="text-xs leading-5", [ngClass]="event.type === 'error' ? 'text-rose-600 dark:text-rose-300' : 'text-sky-900 dark:text-sky-100'")
                                        i(*ngIf="event.type === 'progress'", class="fa-solid fa-spinner fa-spin mr-1")
                                        span(class="font-semibold") {{event.label || (event.type === 'provider' ? 'model' : event.type)}}
                                        span  · {{event.message || event.text || event.provider?.label + ' / ' + event.provider?.model}}
                        div(*ngIf="aiEditProposal", class="rounded-md border border-zinc-200 dark:border-zinc-800")
                            div(class="border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                                h3(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 변경 요약
                                p(*ngIf="aiEditResult?.summary", class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") {{aiEditResult.summary}}
                            div(class="max-h-72 space-y-2 overflow-auto p-4")
                                div(*ngIf="aiEditChanges().length === 0", class="text-sm text-zinc-500 dark:text-zinc-400") 변경된 항목이 없습니다.
                                div(*ngFor="let row of aiEditChanges()", class="rounded-md border border-zinc-200 px-3 py-2 text-xs dark:border-zinc-800")
                                    p(class="font-semibold text-zinc-950 dark:text-zinc-50") {{row.label}}
                                    p(class="mt-1 truncate text-zinc-500 dark:text-zinc-400") 이전: {{row.before}}
                                    p(class="mt-1 truncate text-sky-700 dark:text-sky-300") 이후: {{row.after}}
                            div(class="flex items-center justify-end gap-2 border-t border-zinc-200 px-4 py-3 dark:border-zinc-800")
                                button(type="button", (click)="rollbackAiEditProposal()", [disabled]="!aiEditRollbackSnapshot", class="inline-flex h-8 items-center gap-2 rounded-md border border-zinc-300 px-2.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800")
                                    i(class="fa-solid fa-rotate-left")
                                    span 롤백
                                button(type="button", (click)="applyAiEditProposal()", [disabled]="aiEditApplied()", class="inline-flex h-8 items-center gap-2 rounded-md bg-zinc-950 px-2.5 text-xs font-semibold text-white hover:bg-zinc-800 disabled:opacity-50 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200")
                                    i(class="fa-solid fa-check")
                                    span {{aiEditApplied() ? '적용됨' : '적용'}}
                        div(*ngIf="aiEditResult?.warnings?.length", class="rounded-md border border-amber-200 bg-amber-50 px-3 py-3 text-xs text-amber-800 dark:border-amber-900/70 dark:bg-amber-950/30 dark:text-amber-200")
                            p(class="font-semibold") 경고
                            p(*ngFor="let warning of aiEditResult.warnings", class="mt-1") {{warning}}

div(*ngIf="createModalOpen()", class="fixed inset-0 z-40 flex items-center justify-center px-4 py-6")
    div(class="absolute inset-0 bg-zinc-950/50", (click)="closeCreateModal()")
    section(class="relative w-full max-w-2xl rounded-md border border-zinc-200 bg-white shadow-xl dark:border-zinc-800 dark:bg-zinc-900")
        div(class="flex items-center justify-between border-b border-zinc-200 px-5 py-4 dark:border-zinc-800")
            div
                h2(class="text-base font-semibold text-zinc-950 dark:text-zinc-50") 새 템플릿 초안
                p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") 기본 메타데이터만 먼저 만들고, 본문은 Monaco 편집기에서 이어서 수정합니다.
            button(type="button", (click)="closeCreateModal()", class="inline-flex h-8 w-8 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800")
                i(class="fa-solid fa-xmark")
        div(class="grid grid-cols-1 gap-4 px-5 py-4 md:grid-cols-2")
            label(class="block md:col-span-2")
                span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 이름
                input(type="text", [(ngModel)]="createForm.name", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
            label(class="block md:col-span-2")
                span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 설명
                textarea([(ngModel)]="createForm.description", rows="4", class="w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
            label(class="block")
                span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 이미지 이름
                input(type="text", [(ngModel)]="createForm.image_name", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
            label(class="block")
                span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 이미지 버전
                input(type="text", [(ngModel)]="createForm.image_version", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
        div(class="flex items-center justify-end gap-2 border-t border-zinc-200 px-5 py-4 dark:border-zinc-800")
            button(type="button", (click)="closeCreateModal()", class="inline-flex h-9 items-center rounded-md border border-zinc-300 px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800") 취소
            button(type="button", (click)="createDraftTemplate()", class="inline-flex h-9 items-center gap-2 rounded-md bg-zinc-950 px-3 text-sm font-semibold text-white hover:bg-zinc-800 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200")
                i(class="fa-solid fa-plus")
                span 편집 시작

div(*ngIf="aiModalOpen()", class="fixed inset-0 z-50 flex items-center justify-center px-4 py-6")
    div(class="absolute inset-0 bg-zinc-950/50", (click)="closeAiModal()")
    section(class="relative max-h-[calc(100vh-3rem)] w-full max-w-4xl overflow-auto rounded-md border border-zinc-200 bg-white shadow-xl dark:border-zinc-800 dark:bg-zinc-900")
        div(class="flex items-center justify-between border-b border-zinc-200 px-5 py-4 dark:border-zinc-800")
            div
                h2(class="text-base font-semibold text-zinc-950 dark:text-zinc-50") AI 새 템플릿 초안
                p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") Docker Infra 템플릿 계약에 맞춰 새 템플릿 초안만 생성합니다.
            button(type="button", (click)="closeAiModal()", class="inline-flex h-8 w-8 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800")
                i(class="fa-solid fa-xmark")
        div(class="grid grid-cols-1 gap-5 px-5 py-4 lg:grid-cols-[1fr_320px]")
            div(class="space-y-4")
                label(class="block")
                    span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 사용할 모델
                    wiz-component-search-select([items]="aiModelOptions()", [value]="aiForm.model_ref", (valueChange)="aiForm.model_ref = $event", [placeholder]="'AI 모델 선택'", [searchPlaceholder]="'모델 검색'", [emptyText]="'시스템 설정에서 모델 목록을 불러오세요.'")
                label(class="block")
                    span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 요청
                    textarea([(ngModel)]="aiForm.intent", rows="10", placeholder="예: PostgreSQL과 Redis를 포함한 Django 서비스 템플릿. 외부 공개 포트는 Django만 8000으로 열고, DB/Redis 비밀번호는 자동 생성값으로 처리.", class="w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                div(*ngIf="aiBusy() || aiStreamRows().length", class="rounded-md border border-zinc-200 px-3 py-3 dark:border-zinc-800")
                    div(class="flex items-center justify-between gap-3")
                        p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") AI 진행 상태
                        span(class="text-[11px] font-semibold text-zinc-400 dark:text-zinc-500") {{aiOutputTokenCount()}} chars
                    div(class="mt-2 max-h-36 space-y-1 overflow-auto")
                        p(*ngFor="let event of aiStreamRows()", class="text-xs leading-5", [ngClass]="event.type === 'error' ? 'text-rose-600 dark:text-rose-300' : 'text-zinc-600 dark:text-zinc-300'")
                            i(*ngIf="event.type === 'progress'", class="fa-solid fa-spinner fa-spin mr-1")
                            span(class="font-semibold") {{event.label || (event.type === 'provider' ? 'model' : event.type)}}
                            span  · {{event.message || event.text || event.provider?.label + ' / ' + event.provider?.model}}
                div(*ngIf="aiResult?.warnings?.length", class="rounded-md border border-amber-200 bg-amber-50 px-3 py-3 text-xs text-amber-800 dark:border-amber-900/70 dark:bg-amber-950/30 dark:text-amber-300")
                    p(class="font-semibold") 경고
                    ul(class="mt-2 space-y-1")
                        li(*ngFor="let warning of aiResult.warnings") {{warning}}
            aside(class="space-y-3")
                div(class="rounded-md border border-zinc-200 p-3 dark:border-zinc-800")
                    p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Input
                    div(class="mt-2 space-y-2")
                        div(*ngFor="let row of templateAiInputRows()", class="rounded-md bg-zinc-50 px-2 py-2 dark:bg-zinc-950")
                            p(class="text-xs font-semibold text-zinc-800 dark:text-zinc-100") {{row.key}}
                            p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") {{row.value}}
                div(class="rounded-md border border-zinc-200 p-3 dark:border-zinc-800")
                    p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Output
                    div(class="mt-2 space-y-2")
                        div(*ngFor="let row of templateAiOutputRows()", class="rounded-md bg-zinc-50 px-2 py-2 dark:bg-zinc-950")
                            p(class="text-xs font-semibold text-zinc-800 dark:text-zinc-100") {{row.key}}
                            p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") {{row.value}}
        div(class="flex items-center justify-end gap-2 border-t border-zinc-200 px-5 py-4 dark:border-zinc-800")
            button(type="button", (click)="closeAiModal()", [disabled]="aiBusy()", class="inline-flex h-9 items-center rounded-md border border-zinc-300 px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800") 취소
            button(type="button", (click)="generateTemplateWithAi()", [disabled]="aiBusy()", class="inline-flex h-9 items-center gap-2 rounded-md bg-sky-600 px-3 text-sm font-semibold text-white hover:bg-sky-500 disabled:opacity-60")
                i(class="fa-solid", [ngClass]="aiBusy() ? 'fa-spinner fa-spin' : 'fa-wand-magic-sparkles'")
                span {{aiBusy() ? '생성 중' : '새 초안 적용'}}

div(*ngIf="fileTreeOpen()", class="fixed inset-0 z-50 flex items-center justify-center bg-zinc-950/60 px-4 py-6")
    section(class="relative max-h-[calc(100vh-3rem)] w-full max-w-5xl overflow-auto rounded-md border border-zinc-200 bg-white shadow-xl dark:border-zinc-800 dark:bg-zinc-900")
        div(class="flex items-center justify-between border-b border-zinc-200 px-5 py-4 dark:border-zinc-800")
            div
                h2(class="text-base font-semibold text-zinc-950 dark:text-zinc-50") 템플릿 파일 관리
                p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") {{detail()?.template?.name || ''}}
            button(type="button", (click)="closeFileTree()", class="inline-flex h-8 w-8 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800")
                i(class="fa-solid fa-xmark")
        div(class="p-5")
            wiz-component-file-tree([title]="'템플릿 파일'", [description]="detail()?.template?.path || templateRoot()", [scope]="'template'", [context]="templateFileTreeContext()", [rootLabel]="detail()?.template?.namespace || 'templates'", [allowUpload]="true", [allowMutate]="true", [allowRead]="true")
