header(class="sticky top-0 z-20 border-b border-zinc-200 bg-white/95 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/95")
    div(class="flex flex-col gap-3 px-5 py-4 md:flex-row md:items-center md:justify-between")
        div
            div(class="flex items-center gap-2 text-xs font-medium text-zinc-500 dark:text-zinc-400")
                i(class="fa-solid fa-file-code")
                span Templates
            h1(class="mt-1 text-xl font-semibold text-zinc-950 dark:text-zinc-50") 템플릿 관리
        button(type="button", (click)="load()", class="inline-flex h-9 items-center gap-2 rounded-md border border-zinc-300 bg-white px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800")
            i(class="fa-solid fa-rotate-right")
            span 새로고침

main(class="space-y-5 px-5 py-5")
    div(*ngIf="loading()", class="h-32 rounded-md border border-zinc-200 bg-white p-5 text-sm text-zinc-500 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-400") 정보를 불러오는 중입니다.
    div(*ngIf="error()", class="rounded-md border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700 dark:border-rose-900/70 dark:bg-rose-950/40 dark:text-rose-300") {{error()}}

    div(*ngIf="!loading() && !error()", class="space-y-5")
        section(class="grid grid-cols-1 gap-3 md:grid-cols-3")
            div(class="rounded-md border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900")
                p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Template root
                p(class="mt-2 truncate text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{setup()?.settings?.template_root || '-'}}
            div(class="rounded-md border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900")
                p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Templates
                p(class="mt-2 text-3xl font-semibold text-zinc-950 dark:text-zinc-50") {{templates().length}}
            div(class="rounded-md border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900")
                p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Versions
                p(class="mt-2 text-3xl font-semibold text-zinc-950 dark:text-zinc-50") {{versions().length}}

        section(class="grid grid-cols-1 gap-5 xl:grid-cols-[1fr_420px]")
            div(class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
                div(class="border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                    h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 템플릿 목록
                div(class="overflow-x-auto")
                    table(class="min-w-full divide-y divide-zinc-100 text-sm dark:divide-zinc-800")
                        thead(class="bg-zinc-50 text-xs text-zinc-500 dark:bg-zinc-900 dark:text-zinc-400")
                            tr
                                th(class="px-4 py-2 text-left font-semibold") Name
                                th(class="px-4 py-2 text-left font-semibold") Namespace
                                th(class="px-4 py-2 text-left font-semibold") Path
                                th(class="px-4 py-2 text-left font-semibold") Version
                                th(class="px-4 py-2 text-left font-semibold") State
                        tbody(class="divide-y divide-zinc-100 dark:divide-zinc-800")
                            tr(*ngFor="let item of templates()")
                                td(class="px-4 py-3 font-semibold text-zinc-950 dark:text-zinc-50") {{item.name}}
                                td(class="px-4 py-3 text-zinc-600 dark:text-zinc-300") {{item.namespace}}
                                td(class="max-w-[18rem] truncate px-4 py-3 text-zinc-600 dark:text-zinc-300") {{item.path}}
                                td(class="px-4 py-3 text-zinc-600 dark:text-zinc-300") {{item.latest_version || '-'}}
                                td(class="px-4 py-3")
                                    span(class="inline-flex rounded-md border px-2 py-1 text-xs font-semibold", [ngClass]="statusClass(item.enabled)") {{item.enabled ? '사용 중' : '꺼짐'}}
                            tr(*ngIf="templates().length === 0")
                                td(colspan="5", class="px-4 py-10 text-center text-sm text-zinc-500 dark:text-zinc-400") 등록된 템플릿 없음

            div(class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
                div(class="border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                    h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") Recent versions
                div(class="divide-y divide-zinc-100 dark:divide-zinc-800")
                    div(*ngFor="let version of versions()", class="px-4 py-3")
                        p(class="truncate text-sm font-semibold text-zinc-950 dark:text-zinc-50") v{{version.version}} · {{version.checksum}}
                        p(class="mt-1 truncate text-xs text-zinc-500 dark:text-zinc-400") {{version.path}} · {{formatDate(version.created_at)}}
                    div(*ngIf="versions().length === 0", class="px-4 py-8 text-center text-sm text-zinc-500 dark:text-zinc-400") 버전 기록 없음
