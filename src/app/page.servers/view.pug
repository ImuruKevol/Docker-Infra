                                                td(class="px-4 py-3 text-right")
                                                    a([routerLink]="['/services']", [queryParams]="serviceDetailQueryParams(group)", class="inline-flex h-8 items-center gap-2 rounded-md border border-zinc-300 px-2.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800")
