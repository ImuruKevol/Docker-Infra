header(class="sticky top-0 z-20 border-b border-zinc-200 bg-white/95 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/95")
    div(class="flex flex-col gap-3 px-5 py-4 md:flex-row md:items-center md:justify-between")
        div
            div(class="flex items-center gap-2 text-xs font-medium text-zinc-500 dark:text-zinc-400")
                i(class="fa-solid fa-cubes")
                span Images
            h1(class="mt-1 text-xl font-semibold text-zinc-950 dark:text-zinc-50") 이미지 관리
        button(type="button", (click)="load()", class="inline-flex h-9 items-center gap-2 rounded-md border border-zinc-300 bg-white px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800")
            i(class="fa-solid fa-rotate-right")
            span 새로고침

main(class="space-y-5 px-5 py-5")
    div(*ngIf="loading()", class="h-32 rounded-md border border-zinc-200 bg-white p-5 text-sm text-zinc-500 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-400") 정보를 불러오는 중입니다.
    div(*ngIf="error()", class="rounded-md border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700 dark:border-rose-900/70 dark:bg-rose-950/40 dark:text-rose-300") {{error()}}

    div(*ngIf="!loading() && !error()", class="space-y-5")
        div(*ngIf="!integration('harbor').enabled", class="rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800 dark:border-amber-900/70 dark:bg-amber-950/30 dark:text-amber-200")
            i(class="fa-solid fa-circle-info mr-2")
            | Harbor 자동 연동은 꺼져 있습니다. 이미지 관리는 로컬/저장된 이미지 목록 중심으로 계속 사용할 수 있습니다.
        section(class="grid grid-cols-1 gap-3 md:grid-cols-3")
            div(class="rounded-md border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900")
                div(class="flex items-center justify-between")
                    div
                        p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Harbor
                        p(class="mt-2 truncate text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{integration('harbor').primary || '-'}}
                    span(class="inline-flex rounded-md border px-2 py-1 text-xs font-semibold", [ngClass]="statusClass(integration('harbor').enabled)") {{integration('harbor').enabled ? '사용 중' : '꺼짐'}}
            div(class="rounded-md border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900")
                div(class="flex items-center justify-between")
                    div
                        p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") GitLab
                        p(class="mt-2 truncate text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{integration('gitlab').primary || '-'}}
                    span(class="inline-flex rounded-md border px-2 py-1 text-xs font-semibold", [ngClass]="statusClass(integration('gitlab').enabled)") {{integration('gitlab').enabled ? '사용 중' : '꺼짐'}}
            div(class="rounded-md border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900")
                p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Stored images
                p(class="mt-2 text-3xl font-semibold text-zinc-950 dark:text-zinc-50") {{images().length}}

        section(class="grid grid-cols-1 gap-5 xl:grid-cols-[1fr_420px]")
            div(class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
                div(class="border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                    h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") Image inventory
                div(class="overflow-x-auto")
                    table(class="min-w-full divide-y divide-zinc-100 text-sm dark:divide-zinc-800")
                        thead(class="bg-zinc-50 text-xs text-zinc-500 dark:bg-zinc-900 dark:text-zinc-400")
                            tr
                                th(class="px-4 py-2 text-left font-semibold") Registry
                                th(class="px-4 py-2 text-left font-semibold") Image
                                th(class="px-4 py-2 text-left font-semibold") Tag
                                th(class="px-4 py-2 text-left font-semibold") Source
                                th(class="px-4 py-2 text-left font-semibold") Created
                        tbody(class="divide-y divide-zinc-100 dark:divide-zinc-800")
                            tr(*ngFor="let image of images()")
                                td(class="px-4 py-3 text-zinc-600 dark:text-zinc-300") {{image.registry}}
                                td(class="px-4 py-3 font-semibold text-zinc-950 dark:text-zinc-50") {{image.name}}
                                td(class="px-4 py-3 text-zinc-600 dark:text-zinc-300") {{image.tag}}
                                td(class="px-4 py-3")
                                    span(class="inline-flex rounded-md border px-2 py-1 text-xs font-semibold", [ngClass]="statusClass(image.source)") {{image.source}}
                                td(class="px-4 py-3 text-zinc-500 dark:text-zinc-400") {{formatDate(image.created_at)}}
                            tr(*ngIf="images().length === 0")
                                td(colspan="5", class="px-4 py-10 text-center text-sm text-zinc-500 dark:text-zinc-400") 등록된 이미지 없음

            div(class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
                div(class="border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                    h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 빌드 이력
                div(class="divide-y divide-zinc-100 dark:divide-zinc-800")
                    div(*ngFor="let build of builds()", class="px-4 py-3")
                        div(class="flex items-center justify-between gap-3")
                            p(class="truncate text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{build.image_name || build.compose_file_path}}
                            span(class="inline-flex rounded-md border px-2 py-1 text-xs font-semibold", [ngClass]="statusClass(build.status)") {{build.status}}
                        p(class="mt-1 truncate text-xs text-zinc-500 dark:text-zinc-400") {{build.service_name || '-'}} · {{formatDate(build.created_at)}}
                    div(*ngIf="builds().length === 0", class="px-4 py-8 text-center text-sm text-zinc-500 dark:text-zinc-400") 빌드 기록 없음
