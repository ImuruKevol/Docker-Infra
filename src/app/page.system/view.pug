                                option(*ngFor="let item of runtimeNodeItems()", [value]="item.node?.id") {{item.node?.name}} · {{item.node?.host}} · {{runtimeNodeStatusLabel(item)}}
                        label(class="block")
                            span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") Ollama Port
                            input(type="number", min="1", max="65535", [(ngModel)]="aiSettings.runtime.node_ollama_port", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                        div(class="block")
                            span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 노드 모델
                            wiz-component-search-select([items]="runtimeModelSelectorItems()", [value]="aiSettings.runtime.selected_model", (valueChange)="selectRuntimeModel($event)", [placeholder]="'모델 선택 안 함'", [searchPlaceholder]="'노드 Ollama 모델 검색'", [emptyText]="'노드를 스캔하고 대상 노드를 선택하세요.'")
                        label(class="block")
                            span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 모델 표시 순서
                            select([(ngModel)]="aiSettings.runtime.model_sort", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                                option(*ngFor="let option of modelSortOptions()", [value]="option.value") {{option.label}}
                    div(class="grid grid-cols-1 gap-3 xl:grid-cols-2")
                        div(*ngFor="let item of aiResources.nodes", class="rounded-md border border-zinc-200 px-3 py-3 dark:border-zinc-800")
                            div(class="flex items-start justify-between gap-3")
                                div
                                    p(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{item.node?.name || '-'}}
                                    p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") {{item.node?.host || '-'}} · {{item.node?.is_local_master ? 'local' : item.node?.role}}
                                div(class="flex flex-wrap justify-end gap-2")
                                    span(class="inline-flex rounded-md border px-2 py-1 text-xs font-semibold", [ngClass]="runtimeNodeStatusClass(item)") {{runtimeNodeStatusLabel(item)}}
                                    span(class="inline-flex rounded-md border px-2 py-1 text-xs font-semibold", [ngClass]="item.resource?.status === 'ok' ? 'border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900/70 dark:bg-emerald-950/40 dark:text-emerald-300' : item.resource?.status === 'error' ? 'border-rose-200 bg-rose-50 text-rose-700 dark:border-rose-900/70 dark:bg-rose-950/40 dark:text-rose-300' : 'border-zinc-200 bg-zinc-50 text-zinc-600 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-300'") {{resourceStatusLabel(item)}}
                            div(class="mt-3 grid grid-cols-2 gap-2 text-sm md:grid-cols-3")
                                div(class="rounded-md border border-zinc-200 px-3 py-2 dark:border-zinc-800")
                                    p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Ollama
                                    p(class="mt-1 font-semibold text-zinc-950 dark:text-zinc-50") {{runtimeNodeModelSummary(item)}}
                                div(class="rounded-md border border-zinc-200 px-3 py-2 dark:border-zinc-800")
                                    p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") CPU
                                    p(class="mt-1 font-semibold text-zinc-950 dark:text-zinc-50") {{resourcePayload(item).cpu?.logical_cores || '-'}} cores
                                div(class="rounded-md border border-zinc-200 px-3 py-2 dark:border-zinc-800")
                                    p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Memory
                                    p(class="mt-1 font-semibold text-zinc-950 dark:text-zinc-50") {{formatBytes(resourcePayload(item).memory?.total)}}
                                div(class="rounded-md border border-zinc-200 px-3 py-2 dark:border-zinc-800")
                                    p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") GPU
                                    p(class="mt-1 font-semibold text-zinc-950 dark:text-zinc-50") {{gpuSummary(item)}}
                                div(class="rounded-md border border-zinc-200 px-3 py-2 dark:border-zinc-800 md:col-span-2")
                                    p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") Driver
                                    p(class="mt-1 font-semibold text-zinc-950 dark:text-zinc-50") NVIDIA {{driverLabel(item, 'nvidia')}} · Radeon {{driverLabel(item, 'radeon')}}
                            p(*ngIf="item.ollama?.message", class="mt-3 text-xs text-zinc-500 dark:text-zinc-400") {{item.ollama.message}}
                            p(*ngIf="item.resource?.check?.stderr", class="mt-2 text-xs text-rose-600 dark:text-rose-300") {{item.resource.check.stderr}}
                            button(type="button", (click)="selectRuntimeNode(item)", class="mt-3 inline-flex h-9 items-center justify-center gap-2 rounded-md border border-zinc-300 px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800")
                                i(class="fa-solid fa-check")
                                span 이 노드 선택
                    button(type="button", (click)="saveAiRuntime()", [disabled]="aiSectionBusy('runtime')", class="inline-flex h-10 w-full items-center justify-center gap-2 rounded-md bg-zinc-950 px-3 text-sm font-semibold text-white hover:bg-zinc-800 disabled:opacity-60 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200")
                        i(class="fa-solid", [ngClass]="aiSectionBusy('runtime') ? 'fa-spinner fa-spin' : 'fa-floppy-disk'")
                        span {{aiSectionBusy('runtime') ? '저장 중...' : '등록 노드 Ollama 저장'}}

div(*ngIf="resetModalOpen()", class="fixed inset-0 z-50 flex items-center justify-center bg-zinc-950/60 px-4")
    div(class="w-full max-w-lg rounded-md border border-zinc-200 bg-white shadow-xl dark:border-zinc-800 dark:bg-zinc-900")
        div(class="border-b border-zinc-200 px-5 py-4 dark:border-zinc-800")
            h2(class="text-base font-semibold text-zinc-950 dark:text-zinc-50") 백업 시스템 초기화
            p(class="mt-1 text-sm text-zinc-500 dark:text-zinc-400") 내부 백업 저장소를 정지하고 Docker Infra에 저장된 백업 시스템 설정을 초기 상태로 되돌립니다.
        div(class="space-y-4 px-5 py-4")
            div(class="rounded-md border border-rose-200 bg-rose-50 px-3 py-2 text-sm leading-6 text-rose-800 dark:border-rose-900/70 dark:bg-rose-950/30 dark:text-rose-200")
                p(class="font-semibold") 되돌릴 수 없는 작업입니다.
                p 저장 데이터 삭제를 선택하면 백업 이미지와 내부 저장소 데이터가 함께 삭제됩니다.
            label(class="flex items-start gap-3 rounded-md border border-zinc-200 p-3 dark:border-zinc-800")
                input(type="checkbox", [ngModel]="resetDeleteData()", (ngModelChange)="resetDeleteData.set($event)", class="mt-1 h-4 w-4 rounded border-zinc-300 text-zinc-950 focus:ring-zinc-500 dark:border-zinc-700")
                span
                    span(class="block text-sm font-semibold text-zinc-950 dark:text-zinc-50") 저장 데이터도 삭제
                    span(class="mt-1 block text-xs leading-5 text-zinc-500 dark:text-zinc-400") 체크를 해제하면 내부 저장소 데이터는 남기고 Docker Infra 설정만 초기화합니다.
            label(class="block")
                span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 확인 문구
                input(type="text", [ngModel]="resetConfirmText()", (ngModelChange)="resetConfirmText.set($event)", placeholder="초기화", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 placeholder:text-zinc-400 focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") 계속하려면 `초기화`를 입력하세요.
        div(class="flex items-center justify-end gap-2 border-t border-zinc-200 px-5 py-4 dark:border-zinc-800")
            button(type="button", (click)="closeBackupResetModal()", [disabled]="backupBusy()", class="inline-flex h-9 items-center justify-center rounded-md border border-zinc-300 px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-60 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800") 취소
            button(type="button", (click)="resetBackupSystem()", [disabled]="backupBusy() || !canResetBackupSystem()", class="inline-flex h-9 items-center justify-center gap-2 rounded-md bg-rose-600 px-3 text-sm font-semibold text-white hover:bg-rose-700 disabled:opacity-60")
                i(class="fa-solid", [ngClass]="backupBusy() ? 'fa-spinner fa-spin' : 'fa-trash-can'")
                span 초기화
