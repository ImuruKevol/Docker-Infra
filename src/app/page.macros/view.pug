header(class="sticky top-0 z-20 border-b border-zinc-200 bg-white/95 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/95")
    div(class="flex flex-col gap-3 px-5 py-4 md:flex-row md:items-center md:justify-between")
        div
            div(class="flex items-center gap-2 text-xs font-medium text-zinc-500 dark:text-zinc-400")
                i(class="fa-solid fa-bolt")
                span 매크로
            h1(class="mt-1 text-xl font-semibold text-zinc-950 dark:text-zinc-50") 전역 매크로
        div(class="flex flex-wrap items-center gap-2")
            button(type="button", (click)="load()", class="inline-flex h-9 items-center gap-2 rounded-md border border-zinc-300 bg-white px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800")
                i(class="fa-solid fa-rotate-right")
                span 새로고침

main(class="space-y-5 px-5 py-5")
    div(*ngIf="loading()", class="h-32 rounded-md border border-zinc-200 bg-white p-5 text-sm text-zinc-500 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-400") 정보를 불러오는 중입니다.
    div(*ngIf="error()", class="rounded-md border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700 dark:border-rose-900/70 dark:bg-rose-950/40 dark:text-rose-300") {{error()}}

    div(*ngIf="!loading() && !error()", class="space-y-5")
        section(class="grid grid-cols-1 gap-3 md:grid-cols-3")
            div(class="rounded-md border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900")
                p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") 전체 매크로
                p(class="mt-2 text-2xl font-semibold text-zinc-950 dark:text-zinc-50") {{summary()?.total || 0}}
            div(class="rounded-md border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900")
                p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") 사용 가능
                p(class="mt-2 text-2xl font-semibold text-zinc-950 dark:text-zinc-50") {{summary()?.enabled || 0}}
            div(class="rounded-md border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900")
                p(class="text-xs font-semibold text-zinc-500 dark:text-zinc-400") 비활성화
                p(class="mt-2 text-2xl font-semibold text-zinc-950 dark:text-zinc-50") {{summary()?.disabled || 0}}

        section(class="grid grid-cols-1 gap-5 xl:grid-cols-[360px_1fr]")
            div(class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
                div(class="space-y-3 border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                    div(class="flex items-center justify-between gap-3")
                        h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 매크로 목록
                        button(type="button", (click)="openAddMacro()", [disabled]="busy()", class="inline-flex h-8 items-center gap-2 rounded-md bg-zinc-950 px-2.5 text-xs font-semibold text-white hover:bg-zinc-800 disabled:opacity-60 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200")
                            i(class="fa-solid fa-plus")
                            span 매크로 추가
                    label(class="block")
                        span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 검색
                        input(type="text", [ngModel]="search()", (ngModelChange)="search.set($event)", placeholder="매크로 이름 검색", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                div(*ngIf="filteredMacros().length === 0", class="px-4 py-10 text-center text-sm text-zinc-500 dark:text-zinc-400") 등록된 전역 매크로가 없습니다.
                div(*ngFor="let macro of filteredMacros()", class="border-t border-zinc-100 px-4 py-4 first:border-t-0 dark:border-zinc-800")
                    button(type="button", (click)="selectMacro(macro.id)", class="block w-full text-left", [ngClass]="selectedMacroId() === macro.id ? 'rounded-md bg-zinc-50 px-2 py-2 dark:bg-zinc-800/60' : ''")
                        div(class="flex items-start justify-between gap-3")
                            div(class="min-w-0")
                                p(class="truncate text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{macro.name}}
                                p(*ngIf="macro.description", class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") {{macro.description}}
                            div(class="flex shrink-0 flex-col items-end gap-1")
                                span(class="inline-flex rounded-md border px-2 py-0.5 text-[11px] font-semibold", [ngClass]="statusClass(macro.enabled)") {{macro.enabled ? '사용 가능' : '비활성화'}}
                                span(*ngIf="macroFileCount(macro)", class="inline-flex items-center gap-1 rounded-md border border-sky-200 bg-sky-50 px-2 py-0.5 text-[11px] font-semibold text-sky-700 dark:border-sky-900/70 dark:bg-sky-950/40 dark:text-sky-300")
                                    i(class="fa-solid fa-paperclip")
                                    span {{macroFileCount(macro)}}

            div(class="rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
                div(class="flex items-center justify-between border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
                    div
                        h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{selectedMacro()?.name || '전역 매크로'}}
                        p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") {{selectedMacro()?.description || '서버 상세의 매크로 탭에서 실행할 수 있습니다.'}}
                    div(*ngIf="selectedMacro()", class="flex items-center gap-2")
                        button(type="button", (click)="openEditMacro(selectedMacro())", [disabled]="busy()", class="inline-flex h-8 items-center gap-2 rounded-md border border-zinc-300 px-2.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800")
                            i(class="fa-solid fa-pen")
                            span 수정
                        button(type="button", (click)="deleteMacro(selectedMacro())", [disabled]="busy()", class="inline-flex h-8 items-center gap-2 rounded-md border border-rose-300 px-2.5 text-xs font-semibold text-rose-700 hover:bg-rose-50 disabled:opacity-50 dark:border-rose-900/70 dark:text-rose-300 dark:hover:bg-rose-950/30")
                            i(class="fa-solid fa-trash")
                            span 삭제
                div(*ngIf="!selectedMacro()", class="px-4 py-14 text-center text-sm text-zinc-500 dark:text-zinc-400") 왼쪽 목록에서 전역 매크로를 선택하세요.
                div(*ngIf="selectedMacro()", class="space-y-4 px-4 py-4")
                    div(class="flex flex-wrap items-center gap-2")
                        span(class="inline-flex rounded-md border px-2 py-0.5 text-[11px] font-semibold", [ngClass]="statusClass(selectedMacro()?.enabled)") {{selectedMacro()?.enabled ? '사용 가능' : '비활성화'}}
                        span(class="inline-flex items-center gap-1 rounded-md border border-zinc-200 px-2 py-0.5 text-[11px] font-semibold text-zinc-600 dark:border-zinc-700 dark:text-zinc-300")
                            i(class="fa-solid fa-paperclip")
                            span {{macroFileSummary(selectedMacro())}}
                        span(class="text-xs text-zinc-500 dark:text-zinc-400") 수정 {{formatDate(selectedMacro()?.updated_at)}}
                    div(*ngIf="macroFilesFor(selectedMacro()).length", class="rounded-md border border-zinc-200 dark:border-zinc-800")
                        div(class="border-b border-zinc-200 px-3 py-2 text-xs font-semibold text-zinc-600 dark:border-zinc-800 dark:text-zinc-300") 첨부 파일
                        div(*ngFor="let file of macroFilesFor(selectedMacro())", class="flex items-center justify-between gap-3 border-t border-zinc-100 px-3 py-2 first:border-t-0 dark:border-zinc-800")
                            div(class="min-w-0 text-xs text-zinc-700 dark:text-zinc-200")
                                i(class="fa-solid fa-file mr-2 text-zinc-400")
                                span {{file.filename}}
                            span(class="shrink-0 text-xs text-zinc-500 dark:text-zinc-400") {{formatFileSize(file.size_bytes)}}
                    pre(class="max-h-[520px] overflow-auto rounded-md bg-zinc-950 px-3 py-3 text-xs text-zinc-100") {{selectedMacro()?.script}}

div(*ngIf="modalOpen()", class="fixed inset-0 z-40 flex items-center justify-center px-4 py-6")
    div(class="absolute inset-0 bg-zinc-950/50", (click)="closeModal()")
    section(class="relative w-full max-w-5xl rounded-md border border-zinc-200 bg-white shadow-xl dark:border-zinc-800 dark:bg-zinc-900")
        div(class="flex items-center justify-between border-b border-zinc-200 px-5 py-4 dark:border-zinc-800")
            div
                h2(class="text-base font-semibold text-zinc-950 dark:text-zinc-50") {{modalTitle()}}
                p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") 모든 서버에서 재사용할 공통 스크립트입니다.
            button(type="button", (click)="closeModal()", [disabled]="busy()", class="inline-flex h-8 w-8 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 disabled:opacity-50 dark:text-zinc-400 dark:hover:bg-zinc-800")
                i(class="fa-solid fa-xmark")
        div(class="grid grid-cols-1 gap-4 px-5 py-4 lg:grid-cols-[320px_1fr]")
            div(class="space-y-4")
                label(class="block")
                    span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 이름
                    input(type="text", [(ngModel)]="macroForm.name", placeholder="예: Docker 점검", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                label(class="block")
                    span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 설명
                    textarea([(ngModel)]="macroForm.description", rows="4", class="w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                label(class="flex items-center gap-2 rounded-md border border-zinc-200 px-3 py-2 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-200")
                    input(type="checkbox", [(ngModel)]="macroForm.enabled", class="h-4 w-4 rounded border-zinc-300 text-zinc-950 focus:ring-zinc-500 dark:border-zinc-700")
                    span 사용 상태 유지
                div(class="rounded-md border border-zinc-200 dark:border-zinc-800")
                    div(class="flex items-center justify-between gap-2 border-b border-zinc-200 px-3 py-2 dark:border-zinc-800")
                        span(class="text-xs font-semibold text-zinc-600 dark:text-zinc-300") 첨부 파일
                        input(#macroFileInput="", type="file", multiple, class="hidden", (change)="selectMacroFiles($event)")
                        button(type="button", (click)="macroFileInput.click()", [disabled]="busy()", class="inline-flex h-8 items-center gap-2 rounded-md border border-zinc-300 px-2.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800")
                            i(class="fa-solid fa-upload")
                            span 추가
                    div(*ngIf="existingMacroFiles().length === 0 && pendingMacroFiles().length === 0", class="px-3 py-4 text-xs text-zinc-500 dark:text-zinc-400") 첨부 파일 없음
                    div(*ngFor="let file of existingMacroFiles()", class="flex items-center justify-between gap-2 border-t border-zinc-100 px-3 py-2 first:border-t-0 dark:border-zinc-800")
                        div(class="min-w-0 text-xs text-zinc-700 dark:text-zinc-200")
                            i(class="fa-solid fa-file mr-2 text-zinc-400")
                            span {{file.filename}}
                            span(class="ml-2 text-zinc-400") {{formatFileSize(file.size_bytes)}}
                        button(type="button", (click)="removeExistingMacroFile(file.id)", [disabled]="busy()", class="inline-flex h-7 w-7 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 disabled:opacity-50 dark:text-zinc-400 dark:hover:bg-zinc-800")
                            i(class="fa-solid fa-xmark")
                    div(*ngFor="let file of pendingMacroFiles(); let i = index", class="flex items-center justify-between gap-2 border-t border-zinc-100 px-3 py-2 first:border-t-0 dark:border-zinc-800")
                        div(class="min-w-0 text-xs text-sky-700 dark:text-sky-300")
                            i(class="fa-solid fa-file-arrow-up mr-2")
                            span {{file.name}}
                            span(class="ml-2 text-zinc-400") {{formatFileSize(file.size)}}
                        button(type="button", (click)="removePendingMacroFile(i)", [disabled]="busy()", class="inline-flex h-7 w-7 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 disabled:opacity-50 dark:text-zinc-400 dark:hover:bg-zinc-800")
                            i(class="fa-solid fa-xmark")
            div(class="rounded-md border border-zinc-200 dark:border-zinc-800")
                nu-monaco-editor([(ngModel)]="macroForm.script", [options]="macroEditorOptions", height="420px")
        div(class="flex items-center justify-end gap-2 border-t border-zinc-200 px-5 py-4 dark:border-zinc-800")
            button(type="button", (click)="closeModal()", [disabled]="busy()", class="inline-flex h-9 items-center rounded-md border border-zinc-300 px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800") 취소
            button(type="button", (click)="saveMacro()", [disabled]="busy()", class="inline-flex h-9 items-center gap-2 rounded-md bg-zinc-950 px-3 text-sm font-semibold text-white hover:bg-zinc-800 disabled:opacity-60 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200")
                i(class="fa-solid fa-floppy-disk")
                span {{modalSubmitLabel()}}
