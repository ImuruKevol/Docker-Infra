header(class="sticky top-0 z-20 border-b border-zinc-200 bg-white/95 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/95")
    div(class="flex flex-col gap-3 px-5 py-4 md:flex-row md:items-center md:justify-between")
        div
            div(class="flex items-center gap-2 text-xs font-medium text-zinc-500 dark:text-zinc-400")
                i(class="fa-solid fa-bolt")
                span 매크로
            h1(class="mt-1 text-xl font-semibold text-zinc-950 dark:text-zinc-50") 매크로
        div(class="flex flex-wrap items-center gap-2")
            button(type="button", (click)="load()", class="inline-flex h-9 items-center gap-2 rounded-md border border-zinc-300 bg-white px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800")
                i(class="fa-solid fa-rotate-right")
                span 새로고침

main(class="space-y-5 px-5 py-5")
    div(*ngIf="loading()", class="h-32 rounded-md border border-zinc-200 bg-white p-5 text-sm text-zinc-500 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-400") 정보를 불러오는 중입니다.
    div(*ngIf="error()", class="rounded-md border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700 dark:border-rose-900/70 dark:bg-rose-950/40 dark:text-rose-300") {{error()}}

    div(*ngIf="!loading() && !error()", class="grid grid-cols-1 gap-5 xl:grid-cols-[340px_minmax(0,1fr)]")
        section(class="min-w-0 overflow-hidden rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
            div(class="border-b border-zinc-200 px-3 py-3 dark:border-zinc-800")
                div(class="flex items-center justify-between gap-3")
                    div
                        h2(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 매크로 목록
                        p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") {{macroBoardSummary()}}
                    button(type="button", (click)="openAddMacro()", [disabled]="busy()", class="inline-flex h-8 shrink-0 items-center gap-2 rounded-md bg-zinc-950 px-2.5 text-xs font-semibold text-white hover:bg-zinc-800 disabled:opacity-60 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200")
                        i(class="fa-solid fa-plus")
                        span 추가
                div(class="mt-3")
                    input(type="text", [ngModel]="search()", (ngModelChange)="setMacroSearch($event)", placeholder="매크로 검색", class="h-8 w-full rounded-md border border-zinc-300 bg-white px-3 text-xs text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")

            div(*ngIf="filteredMacros().length > 0", class="divide-y divide-zinc-100 dark:divide-zinc-800")
                button(*ngFor="let macro of pagedMacros()", type="button", (click)="selectMacro(macro.id)", class="block w-full px-3 py-2 text-left transition hover:bg-zinc-50 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-sky-500 dark:hover:bg-zinc-800/60", [ngClass]="selectedMacroId() === macro.id && !isEditingMacro() ? 'bg-sky-50 dark:bg-sky-950/20' : ''")
                    div(class="flex min-w-0 items-center justify-between gap-2")
                        div(class="min-w-0")
                            p(class="truncate text-sm font-semibold text-zinc-950 dark:text-zinc-50", [title]="macro.name") {{macro.name}}
                        span(*ngIf="macroFileCount(macro)", class="inline-flex shrink-0 items-center gap-1 rounded-md border border-zinc-200 px-2 py-0.5 text-[11px] font-semibold text-zinc-600 dark:border-zinc-700 dark:text-zinc-300")
                            i(class="fa-solid fa-paperclip")
                            span {{macroFileCount(macro)}}
            div(*ngIf="filteredMacros().length === 0", class="px-3 py-8 text-center text-sm text-zinc-500 dark:text-zinc-400") 등록된 매크로가 없습니다.
            div(*ngIf="macroPagination().total > 0", class="flex flex-col gap-2 border-t border-zinc-200 px-3 py-2 dark:border-zinc-800")
                p(class="text-xs font-medium text-zinc-500 dark:text-zinc-400") 페이지당 10개
                wiz-portal-season-pagination([current]="macroPagination().current", [start]="macroPagination().start", [end]="macroPagination().end", [maxlength]="10", (pageMove)="moveMacroPage($event)")

        section(class="min-w-0 overflow-hidden rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900")
            div(*ngIf="!selectedMacro() && !isEditingMacro()", class="flex min-h-[620px] items-center justify-center px-4 py-14 text-center text-sm text-zinc-500 dark:text-zinc-400") 왼쪽 목록에서 매크로를 선택하세요.

            div(*ngIf="selectedMacro() && !isEditingMacro()", class="flex min-h-[620px] flex-col")
                div(class="flex flex-col gap-3 border-b border-zinc-200 px-4 py-3 dark:border-zinc-800 lg:flex-row lg:items-start lg:justify-between")
                    div(class="min-w-0")
                        h2(class="truncate text-base font-semibold text-zinc-950 dark:text-zinc-50") {{selectedMacro()?.name}}
                        p(class="mt-1 whitespace-pre-line text-xs text-zinc-500 dark:text-zinc-400") {{selectedMacroDescription()}}
                    div(class="flex shrink-0 items-center gap-2")
                        button(type="button", (click)="openScheduleModal(selectedMacro())", [disabled]="busy()", class="inline-flex h-8 items-center gap-2 rounded-md border border-zinc-300 px-2.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800")
                            i(class="fa-solid fa-calendar-days")
                            span 스케줄
                            span(class="inline-flex min-w-5 justify-center rounded bg-zinc-100 px-1.5 py-0.5 text-[10px] text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300") {{selectedMacroScheduleCount()}}
                        button(type="button", (click)="openEditMacro(selectedMacro())", [disabled]="busy()", class="inline-flex h-8 items-center gap-2 rounded-md border border-zinc-300 px-2.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800")
                            i(class="fa-solid fa-pen")
                            span 수정
                        button(type="button", (click)="deleteMacro(selectedMacro())", [disabled]="busy()", class="inline-flex h-8 items-center gap-2 rounded-md border border-rose-300 px-2.5 text-xs font-semibold text-rose-700 hover:bg-rose-50 disabled:opacity-50 dark:border-rose-900/70 dark:text-rose-300 dark:hover:bg-rose-950/30")
                            i(class="fa-solid fa-trash")
                            span 삭제

                div(class="space-y-4 border-b border-zinc-200 px-4 py-4 dark:border-zinc-800")
                    div(class="grid grid-cols-1 gap-2 xl:grid-cols-[auto_minmax(0,1fr)_minmax(0,1fr)_auto]")
                        div(class="inline-flex h-10 rounded-md border border-zinc-300 bg-white p-1 dark:border-zinc-700 dark:bg-zinc-950")
                            button(type="button", (click)="setRunTargetType('server')", class="inline-flex h-8 items-center justify-center rounded px-3 text-xs font-semibold", [ngClass]="runTargetType() === 'server' ? 'bg-zinc-950 text-white dark:bg-zinc-100 dark:text-zinc-950' : 'text-zinc-600 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800'")
                                i(class="fa-solid fa-server mr-1.5")
                                span 서버
                            button(type="button", (click)="setRunTargetType('service')", class="inline-flex h-8 items-center justify-center rounded px-3 text-xs font-semibold", [ngClass]="runTargetType() === 'service' ? 'bg-zinc-950 text-white dark:bg-zinc-100 dark:text-zinc-950' : 'text-zinc-600 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800'")
                                i(class="fa-solid fa-cube mr-1.5")
                                span 서비스
                        div(*ngIf="runTargetType() === 'server'", class="min-w-0 xl:col-span-2")
                            wiz-component-search-select([items]="serverTargetItems()", [value]="selectedNodeId()", (valueChange)="selectedNodeId.set($event)", [placeholder]="'서버 선택'", [searchPlaceholder]="'서버 검색'", [emptyText]="'등록된 서버가 없습니다.'")
                        div(*ngIf="runTargetType() === 'service'", class="min-w-0")
                            wiz-component-search-select([items]="serviceTargetServiceItems()", [value]="selectedServiceId()", (valueChange)="selectServiceTargetService($event)", [placeholder]="'서비스 선택'", [searchPlaceholder]="'서비스 검색'", [emptyText]="'실행 중인 서비스가 없습니다.'")
                        div(*ngIf="runTargetType() === 'service'", class="min-w-0")
                            wiz-component-search-select([items]="serviceContainerTargetItems()", [value]="selectedServiceTargetId()", (valueChange)="selectServiceContainerTarget($event)", [placeholder]="'컨테이너 선택'", [searchPlaceholder]="'컨테이너 검색'", [emptyText]="'선택한 서비스에 실행 중인 컨테이너가 없습니다.'", [disabled]="!selectedServiceId()")
                        button(type="button", (click)="runSelectedMacro()", [disabled]="!canRunSelectedMacro()", class="inline-flex h-10 items-center justify-center gap-2 rounded-md bg-zinc-950 px-3 text-sm font-semibold text-white hover:bg-zinc-800 disabled:opacity-50 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200")
                            i(class="fa-solid", [ngClass]="busy() ? 'fa-spinner fa-spin' : 'fa-play'")
                            span 실행
                    div(class="grid grid-cols-1 gap-2 lg:grid-cols-[auto_minmax(0,1fr)] lg:items-center")
                        label(class="inline-flex w-fit max-w-full items-center gap-2 rounded-md border border-zinc-200 px-3 py-2 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-200")
                            input(type="checkbox", [ngModel]="macroArgsEnabled()", (ngModelChange)="macroArgsEnabled.set($event)", class="h-4 w-4 rounded border-zinc-300 text-zinc-950 focus:ring-zinc-500 dark:border-zinc-700")
                            span 실행 인자 사용
                        input(*ngIf="macroArgsEnabled()", type="text", [ngModel]="macroArgsInput()", (ngModelChange)="macroArgsInput.set($event)", placeholder="예: --force prod", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                    div(*ngIf="runTargetError()", class="rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-700 dark:border-amber-900/70 dark:bg-amber-950/40 dark:text-amber-300") {{runTargetError()}}
                    div(*ngIf="macroRunResult()", class="rounded-md border border-zinc-200 dark:border-zinc-800")
                        div(class="flex flex-col gap-2 border-b border-zinc-200 px-3 py-2 dark:border-zinc-800 md:flex-row md:items-center md:justify-between")
                            p(class="text-xs font-semibold text-zinc-600 dark:text-zinc-300") {{macroRunTargetLabel()}}
                            span(class="inline-flex w-fit rounded-md border px-2 py-0.5 text-[11px] font-semibold", [ngClass]="operationStatusClass(macroRunStatus())") {{operationStatusLabel(macroRunStatus())}}
                        pre(*ngIf="macroRunLogText()", data-macro-run-output="true", class="max-h-52 overflow-auto bg-zinc-50 px-3 py-3 font-mono text-xs leading-5 text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100") {{macroRunLogText()}}
                        div(*ngIf="!macroRunLogText()", class="px-3 py-6 text-center text-sm text-zinc-500 dark:text-zinc-400") 실행 로그를 기다리는 중입니다.

                div(class="space-y-4 px-4 py-4")
                    div(*ngIf="macroFilesFor(selectedMacro()).length", class="rounded-md border border-zinc-200 dark:border-zinc-800")
                        div(class="border-b border-zinc-200 px-3 py-2 text-xs font-semibold text-zinc-600 dark:border-zinc-800 dark:text-zinc-300") 첨부 파일
                        div(*ngFor="let file of macroFilesFor(selectedMacro())", class="flex items-center justify-between gap-3 border-t border-zinc-100 px-3 py-2 first:border-t-0 dark:border-zinc-800")
                            button(type="button", (click)="downloadMacroFile(file, $event)", class="flex min-w-0 flex-1 items-center text-left text-xs text-zinc-700 hover:text-zinc-950 dark:text-zinc-200 dark:hover:text-zinc-50")
                                i(class="fa-solid fa-file-arrow-down mr-2 text-zinc-400")
                                span(class="truncate") {{file.filename}}
                            div(class="flex shrink-0 items-center gap-2")
                                span(class="text-xs text-zinc-500 dark:text-zinc-400") {{formatFileSize(file.size_bytes)}}
                                button(type="button", (click)="deleteMacroFile(file, $event)", [disabled]="busy()", class="inline-flex h-7 w-7 items-center justify-center rounded-md text-zinc-500 hover:bg-rose-50 hover:text-rose-700 disabled:opacity-50 dark:text-zinc-400 dark:hover:bg-rose-950/30 dark:hover:text-rose-300")
                                    i(class="fa-solid fa-trash")
                    div
                        div(class="mb-2 flex items-center justify-between gap-2")
                            h3(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 코드
                            span(class="text-xs text-zinc-500 dark:text-zinc-400") shell
                        pre(class="min-h-[340px] max-h-[560px] overflow-auto rounded-md border border-zinc-200 bg-zinc-50 px-3 py-3 font-mono text-xs leading-5 text-zinc-900 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100") {{selectedMacro()?.script}}

            div(*ngIf="isEditingMacro()", class="flex min-h-[620px] flex-col")
                div(class="flex flex-col gap-3 border-b border-zinc-200 px-4 py-3 dark:border-zinc-800 lg:flex-row lg:items-center lg:justify-between")
                    div
                        h2(class="text-base font-semibold text-zinc-950 dark:text-zinc-50") {{formTitle()}}
                        p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") 이름, 첨부 파일, 실행 코드를 한 화면에서 관리합니다.
                    div(class="flex items-center gap-2")
                        button(type="button", (click)="cancelEditMacro()", [disabled]="busy()", class="inline-flex h-8 items-center rounded-md border border-zinc-300 px-2.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800") 취소
                        button(type="button", (click)="saveMacro()", [disabled]="busy()", class="inline-flex h-8 items-center gap-2 rounded-md bg-zinc-950 px-2.5 text-xs font-semibold text-white hover:bg-zinc-800 disabled:opacity-60 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200")
                            i(class="fa-solid fa-floppy-disk")
                            span {{formSubmitLabel()}}
                div(class="grid flex-1 grid-cols-1 gap-4 px-4 py-4 lg:grid-cols-[320px_minmax(0,1fr)]")
                    div(class="space-y-4")
                        label(class="block")
                            span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 이름
                            input(type="text", [(ngModel)]="macroForm.name", placeholder="예: Docker 점검", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                        label(class="block")
                            span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 설명
                            textarea([(ngModel)]="macroForm.description", rows="4", class="w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                        div(class="rounded-md border border-zinc-200 dark:border-zinc-800")
                            div(class="flex items-center justify-between gap-2 border-b border-zinc-200 px-3 py-2 dark:border-zinc-800")
                                span(class="text-xs font-semibold text-zinc-600 dark:text-zinc-300") 첨부 파일
                                input(#macroFileInput="", type="file", multiple, class="hidden", (change)="selectMacroFiles($event)")
                                button(type="button", (click)="macroFileInput.click()", [disabled]="busy()", class="inline-flex h-8 items-center gap-2 rounded-md border border-zinc-300 px-2.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800")
                                    i(class="fa-solid fa-upload")
                                    span 추가
                            div(*ngIf="existingMacroFiles().length === 0 && pendingMacroFiles().length === 0", class="px-3 py-4 text-xs text-zinc-500 dark:text-zinc-400") 첨부 파일 없음
                            div(*ngFor="let file of existingMacroFiles()", class="flex items-center justify-between gap-2 border-t border-zinc-100 px-3 py-2 first:border-t-0 dark:border-zinc-800")
                                div(class="min-w-0 text-xs text-zinc-700 dark:text-zinc-200")
                                    i(class="fa-solid fa-file mr-2 text-zinc-400")
                                    span {{file.filename}}
                                    span(class="ml-2 text-zinc-400") {{formatFileSize(file.size_bytes)}}
                                button(type="button", (click)="removeExistingMacroFile(file.id)", [disabled]="busy()", class="inline-flex h-7 w-7 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 disabled:opacity-50 dark:text-zinc-400 dark:hover:bg-zinc-800")
                                    i(class="fa-solid fa-xmark")
                            div(*ngFor="let file of pendingMacroFiles(); let i = index", class="flex items-center justify-between gap-2 border-t border-zinc-100 px-3 py-2 first:border-t-0 dark:border-zinc-800")
                                div(class="min-w-0 text-xs text-sky-700 dark:text-sky-300")
                                    i(class="fa-solid fa-file-arrow-up mr-2")
                                    span {{file.name}}
                                    span(class="ml-2 text-zinc-400") {{formatFileSize(file.size)}}
                                button(type="button", (click)="removePendingMacroFile(i)", [disabled]="busy()", class="inline-flex h-7 w-7 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 disabled:opacity-50 dark:text-zinc-400 dark:hover:bg-zinc-800")
                                    i(class="fa-solid fa-xmark")
                    div(class="min-w-0 rounded-md border border-zinc-200 dark:border-zinc-800")
                        nu-monaco-editor([(ngModel)]="macroForm.script", [options]="macroEditorOptions", height="520px")

div(*ngIf="scheduleModalOpen()", class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 px-4 py-6")
    div(class="flex max-h-[88vh] w-full max-w-7xl flex-col overflow-hidden rounded-md border border-zinc-200 bg-white shadow-xl dark:border-zinc-800 dark:bg-zinc-900")
        div(class="flex items-center justify-between gap-3 border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
            div(class="min-w-0")
                h2(class="truncate text-base font-semibold text-zinc-950 dark:text-zinc-50") {{selectedMacro()?.name}} 스케줄
                p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") {{selectedMacroScheduleCount()}}개 등록
            button(type="button", (click)="closeScheduleModal()", class="inline-flex h-8 w-8 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800")
                i(class="fa-solid fa-xmark")
        div(class="grid min-h-0 flex-1 grid-cols-1 overflow-hidden lg:grid-cols-[300px_minmax(0,1fr)]")
            aside(class="min-h-0 overflow-auto border-b border-zinc-200 p-3 dark:border-zinc-800 lg:border-b-0 lg:border-r")
                div(class="mb-3 flex items-center justify-between gap-2")
                    h3(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 등록 스케줄
                    button(type="button", (click)="newScheduleForm()", class="inline-flex h-8 items-center gap-2 rounded-md bg-zinc-950 px-2.5 text-xs font-semibold text-white hover:bg-zinc-800 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200")
                        i(class="fa-solid fa-plus")
                        span 추가
                div(*ngIf="macroSchedules().length === 0", class="rounded-md border border-dashed border-zinc-300 px-3 py-8 text-center text-sm text-zinc-500 dark:border-zinc-700 dark:text-zinc-400") 등록된 스케줄이 없습니다.
                div(*ngIf="macroSchedules().length > 0", class="space-y-2")
                    button(*ngFor="let schedule of macroSchedules()", type="button", (click)="selectScheduleForm(schedule)", class="w-full rounded-md border px-3 py-2 text-left transition hover:bg-zinc-50 dark:hover:bg-zinc-800/70", [ngClass]="scheduleForm?.id === schedule.id ? 'border-sky-300 bg-sky-50 dark:border-sky-900/70 dark:bg-sky-950/30' : 'border-zinc-200 dark:border-zinc-800'")
                        div(class="flex items-center justify-between gap-2")
                            p(class="truncate text-sm font-semibold text-zinc-950 dark:text-zinc-50") {{schedule.name || '이름 없는 스케줄'}}
                            span(class="inline-flex rounded-md border px-2 py-0.5 text-[11px] font-semibold", [ngClass]="scheduleStatusClass(schedule)") {{schedule.enabled ? '사용' : '꺼짐'}}
                        p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") {{scheduleSummary(schedule)}} · {{scheduleTargetSummary(schedule)}}
                        p(class="mt-1 text-[11px] text-zinc-400 dark:text-zinc-500") {{scheduleLastRunLabel(schedule)}}
            section(class="min-h-0 overflow-auto p-4")
                div(class="grid grid-cols-1 gap-4 xl:grid-cols-[minmax(0,1fr)_360px]")
                    div(class="space-y-4")
                        div(class="grid grid-cols-1 gap-3 md:grid-cols-[minmax(0,1fr)_auto]")
                            label(class="block")
                                span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 이름
                                input(type="text", [(ngModel)]="scheduleForm.name", placeholder="예: 주간 점검", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                            label(class="inline-flex h-10 items-center gap-2 self-end rounded-md border border-zinc-200 px-3 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-200")
                                input(type="checkbox", [(ngModel)]="scheduleForm.enabled", class="h-4 w-4 rounded border-zinc-300 text-zinc-950 focus:ring-zinc-500 dark:border-zinc-700")
                                span 사용
                        div(class="rounded-md border border-zinc-200 p-3 dark:border-zinc-800")
                            div(class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between")
                                div
                                    h3(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 실행 일정
                                div(class="inline-flex h-9 rounded-md bg-zinc-100 p-1 dark:bg-zinc-950")
                                    button(*ngFor="let item of macroScheduleTypes()", type="button", (click)="setScheduleType(item.key)", class="inline-flex h-7 items-center gap-2 rounded px-3 text-xs font-semibold transition-colors", [ngClass]="scheduleForm.schedule_type === item.key ? 'bg-white text-zinc-950 shadow-sm dark:bg-zinc-800 dark:text-zinc-50' : 'text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100'")
                                        i(class="fa-solid", [ngClass]="item.icon")
                                        span {{item.label}}
                            div(*ngIf="scheduleForm.schedule_type === 'weekly'", class="mt-3")
                                div(class="grid grid-cols-7 gap-1.5")
                                    button(*ngFor="let day of weekdayOptions()", type="button", (click)="toggleScheduleWeekday(day.value)", class="h-9 rounded-md border text-xs font-semibold transition-colors", [ngClass]="isScheduleWeekdaySelected(day.value) ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-200 bg-white text-zinc-600 hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:bg-zinc-800'") {{day.label}}
                            div(class="mt-3 grid grid-cols-1 gap-3 md:grid-cols-2")
                                label(*ngIf="scheduleForm.schedule_type === 'monthly'", class="block")
                                    span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 매월 실행일
                                    input(type="number", min="1", max="31", [(ngModel)]="scheduleForm.schedule_month_day", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                                label(class="block")
                                    span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 실행 시간
                                    input(type="time", [(ngModel)]="scheduleForm.schedule_time", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm font-semibold text-zinc-900 focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                        div(class="rounded-md border border-zinc-200 p-3 dark:border-zinc-800")
                            div(class="flex flex-col gap-3 md:flex-row md:items-center")
                                div(class="shrink-0")
                                    h3(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 실행 대상
                                    p(class="mt-1 text-xs text-zinc-500 dark:text-zinc-400") {{scheduleTargetCount()}}개 선택
                                input(type="text", [ngModel]="scheduleTargetSearch()", (ngModelChange)="scheduleTargetSearch.set($event)", placeholder="대상 검색", class="h-9 min-w-0 flex-1 rounded-md border border-zinc-300 bg-white px-3 text-xs text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                                div(class="inline-flex h-9 rounded-md border border-zinc-300 bg-white p-1 dark:border-zinc-700 dark:bg-zinc-950")
                                    button(type="button", (click)="setScheduleTargetType('server')", class="inline-flex h-7 items-center justify-center rounded px-3 text-xs font-semibold", [ngClass]="scheduleForm.target_type === 'server' ? 'bg-zinc-950 text-white dark:bg-zinc-100 dark:text-zinc-950' : 'text-zinc-600 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800'")
                                        i(class="fa-solid fa-server mr-1.5")
                                        span 서버
                                    button(type="button", (click)="setScheduleTargetType('service')", class="inline-flex h-7 items-center justify-center rounded px-3 text-xs font-semibold", [ngClass]="scheduleForm.target_type === 'service' ? 'bg-zinc-950 text-white dark:bg-zinc-100 dark:text-zinc-950' : 'text-zinc-600 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800'")
                                        i(class="fa-solid fa-cube mr-1.5")
                                        span 서비스
                            div(*ngIf="scheduleTargetItems().length === 0", class="mt-3 flex h-72 items-center justify-center rounded-md border border-dashed border-zinc-300 px-3 text-center text-sm text-zinc-500 dark:border-zinc-700 dark:text-zinc-400") 선택 가능한 대상이 없습니다.
                            div(*ngIf="scheduleTargetItems().length > 0", class="mt-3 grid h-72 grid-cols-1 gap-2 overflow-auto pr-1")
                                button(*ngFor="let item of scheduleTargetItems()", type="button", (click)="toggleScheduleTarget(item.value)", class="flex min-h-16 items-start gap-3 rounded-md border px-3 py-2 text-left transition hover:bg-zinc-50 dark:hover:bg-zinc-800/70", [ngClass]="isScheduleTargetSelected(item.value) ? 'border-sky-300 bg-sky-50 dark:border-sky-900/70 dark:bg-sky-950/30' : 'border-zinc-200 dark:border-zinc-800'")
                                    span(class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded border text-[11px]", [ngClass]="isScheduleTargetSelected(item.value) ? 'border-sky-500 bg-sky-500 text-white dark:border-sky-400 dark:bg-sky-400 dark:text-zinc-950' : 'border-zinc-300 text-transparent dark:border-zinc-700'")
                                        i(class="fa-solid fa-check")
                                    span(class="min-w-0")
                                        span(class="block truncate text-sm font-semibold text-zinc-900 dark:text-zinc-50") {{item.label}}
                                        span(class="mt-1 block truncate text-xs text-zinc-500 dark:text-zinc-400") {{item.description || '-'}}
                        label(class="block")
                            span(class="mb-1 block text-xs font-semibold text-zinc-500 dark:text-zinc-400") 실행 인자
                            input(type="text", [(ngModel)]="scheduleForm.args", placeholder="예: --force prod", class="h-10 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-900 placeholder:text-zinc-400 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100")
                    aside(class="flex h-full min-h-[520px] flex-col rounded-md border border-zinc-200 p-3 dark:border-zinc-800")
                        div(class="mb-3 flex items-center justify-between gap-2")
                            h3(class="text-sm font-semibold text-zinc-950 dark:text-zinc-50") 실행 이력
                            span(class="text-xs font-medium text-zinc-500 dark:text-zinc-400") {{scheduleHistorySummary()}}
                        div(*ngIf="scheduleHistoryError()", class="mb-2 rounded-md border border-rose-200 bg-rose-50 px-3 py-2 text-xs text-rose-700 dark:border-rose-900/70 dark:bg-rose-950/40 dark:text-rose-300") {{scheduleHistoryError()}}
                        div(*ngIf="scheduleHistoryLoading()", class="flex min-h-0 flex-1 items-center justify-center rounded-md border border-dashed border-zinc-300 px-3 text-center text-sm text-zinc-500 dark:border-zinc-700 dark:text-zinc-400") 실행 이력을 불러오는 중입니다.
                        div(*ngIf="!scheduleHistoryLoading() && scheduleHistory().length === 0", class="flex min-h-0 flex-1 items-center justify-center rounded-md border border-dashed border-zinc-300 px-3 text-center text-sm text-zinc-500 dark:border-zinc-700 dark:text-zinc-400") 아직 실행 이력이 없습니다.
                        div(*ngIf="!scheduleHistoryLoading() && scheduleHistory().length > 0", class="min-h-0 flex-1 space-y-2 overflow-auto pr-1")
                            button(*ngFor="let item of scheduleHistory()", type="button", (click)="openScheduleHistoryResult(item)", class="w-full rounded-md border border-zinc-200 px-3 py-2 text-left transition hover:bg-zinc-50 dark:border-zinc-800 dark:hover:bg-zinc-800/70")
                                div(class="flex items-center justify-between gap-2")
                                    span(class="inline-flex rounded-md border px-2 py-0.5 text-[11px] font-semibold", [ngClass]="operationStatusClass(item.status)") {{operationStatusLabel(item.status)}}
                                    span(class="shrink-0 text-[11px] text-zinc-400 dark:text-zinc-500") {{scheduleHistoryDateTimeLabel(item)}}
                                p(class="mt-2 truncate text-sm font-semibold text-zinc-900 dark:text-zinc-50") {{scheduleHistoryTargetLabel(item)}}
                        div(*ngIf="!scheduleHistoryLoading() && scheduleHistoryPagination().total > scheduleHistoryPagination().limit", class="mt-3 flex flex-col gap-2 border-t border-zinc-200 pt-3 dark:border-zinc-800")
                            p(class="text-xs font-medium text-zinc-500 dark:text-zinc-400") {{scheduleHistoryPageSummary()}}
                            wiz-portal-season-pagination([current]="scheduleHistoryPagination().current", [start]="scheduleHistoryPagination().start", [end]="scheduleHistoryPagination().end", [maxlength]="10", (pageMove)="moveScheduleHistoryPage($event)")
        div(class="flex items-center justify-between gap-3 border-t border-zinc-200 px-4 py-3 dark:border-zinc-800")
            button(type="button", *ngIf="scheduleForm?.id", (click)="deleteSchedule(scheduleForm)", [disabled]="busy()", class="inline-flex h-9 items-center gap-2 rounded-md border border-rose-300 px-3 text-sm font-semibold text-rose-700 hover:bg-rose-50 disabled:opacity-50 dark:border-rose-900/70 dark:text-rose-300 dark:hover:bg-rose-950/30")
                i(class="fa-solid fa-trash")
                span 삭제
            span(*ngIf="!scheduleForm?.id")
            div(class="flex items-center gap-2")
                button(type="button", (click)="closeScheduleModal()", [disabled]="busy()", class="inline-flex h-9 items-center rounded-md border border-zinc-300 px-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800") 닫기
                button(type="button", (click)="saveSchedule()", [disabled]="!canSaveSchedule()", class="inline-flex h-9 items-center gap-2 rounded-md bg-zinc-950 px-3 text-sm font-semibold text-white hover:bg-zinc-800 disabled:opacity-50 dark:bg-zinc-100 dark:text-zinc-950 dark:hover:bg-zinc-200")
                    i(class="fa-solid", [ngClass]="busy() ? 'fa-spinner fa-spin' : 'fa-floppy-disk'")
                    span 저장

div(*ngIf="scheduleHistoryResultOpen()", class="fixed inset-0 z-[60] flex items-center justify-center bg-black/50 px-4 py-6")
    div(class="flex max-h-[82vh] w-full max-w-4xl flex-col overflow-hidden rounded-md border border-zinc-200 bg-white shadow-2xl dark:border-zinc-800 dark:bg-zinc-900")
        div(class="flex items-center justify-between gap-3 border-b border-zinc-200 px-4 py-3 dark:border-zinc-800")
            div(class="min-w-0")
                h2(class="truncate text-base font-semibold text-zinc-950 dark:text-zinc-50") 실행 결과
                p(class="mt-1 truncate text-xs text-zinc-500 dark:text-zinc-400") {{scheduleHistoryDateTimeLabel(scheduleHistoryResultItem())}} / {{scheduleHistoryTargetLabel(scheduleHistoryResultItem())}}
            button(type="button", (click)="closeScheduleHistoryResult()", class="inline-flex h-8 w-8 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800")
                i(class="fa-solid fa-xmark")
        div(class="min-h-0 flex-1 overflow-auto p-4")
            div(class="mb-3 flex flex-wrap items-center gap-2")
                span(class="inline-flex rounded-md border px-2 py-0.5 text-[11px] font-semibold", [ngClass]="operationStatusClass(scheduleHistoryActiveOperation()?.status || scheduleHistoryResultItem()?.status)") {{operationStatusLabel(scheduleHistoryActiveOperation()?.status || scheduleHistoryResultItem()?.status)}}
                span(class="text-xs text-zinc-500 dark:text-zinc-400") {{scheduleHistoryTargetLabel(scheduleHistoryActiveOperation())}}
                span(class="text-xs text-zinc-400 dark:text-zinc-500") {{scheduleHistoryDateTimeLabel(scheduleHistoryActiveOperation())}}
            div(*ngIf="scheduleHistoryResultOperations().length > 1", class="mb-3 flex flex-wrap gap-2")
                button(*ngFor="let operation of scheduleHistoryResultOperations(); let i = index", type="button", (click)="selectScheduleHistoryResultOperation(operation)", class="inline-flex min-h-8 max-w-full items-center gap-2 rounded-md border px-3 py-1.5 text-xs font-semibold transition", [ngClass]="scheduleHistoryActiveOperation()?.id === operation.id ? 'border-zinc-950 bg-zinc-950 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950' : 'border-zinc-200 text-zinc-600 hover:bg-zinc-50 dark:border-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-800'")
                    span(class="truncate") {{scheduleHistoryOperationTabLabel(operation, i)}}
                    span(class="shrink-0 rounded border px-1.5 py-0.5 text-[10px]", [ngClass]="operationStatusClass(operation.status)") {{operationStatusLabel(operation.status)}}
            div(class="space-y-3")
                section(class="min-h-48 rounded-md border border-zinc-200 bg-zinc-50 p-3 dark:border-zinc-800 dark:bg-zinc-950")
                    h3(class="text-xs font-semibold text-zinc-700 dark:text-zinc-200") stdout
                    pre(*ngIf="scheduleHistoryStdoutText()", class="mt-2 max-h-80 overflow-auto whitespace-pre-wrap break-words font-mono text-[11px] leading-5 text-zinc-800 dark:text-zinc-100") {{scheduleHistoryStdoutText()}}
                    div(*ngIf="!scheduleHistoryStdoutText()", class="mt-2 text-xs text-zinc-500 dark:text-zinc-400") stdout 출력이 없습니다.
                section(*ngIf="scheduleHistoryStderrText()", class="min-h-48 rounded-md border border-zinc-200 bg-zinc-50 p-3 dark:border-zinc-800 dark:bg-zinc-950")
                    h3(class="text-xs font-semibold text-zinc-700 dark:text-zinc-200") stderr
                    pre(class="mt-2 max-h-80 overflow-auto whitespace-pre-wrap break-words font-mono text-[11px] leading-5 text-zinc-800 dark:text-zinc-100") {{scheduleHistoryStderrText()}}
